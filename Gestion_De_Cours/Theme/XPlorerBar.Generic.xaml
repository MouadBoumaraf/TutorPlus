<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:xpbar="clr-namespace:ZonaTools.XPlorerBar">


    <!-- ========================== -->
    <!-- = Expand/Collapse arrows = -->
    <!-- ========================== -->
    <Geometry x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type xpbar:XPlorerResourceKeys},ResourceId=XPlorerSectionHeaderCollapseArrows}">
        M0,4 L4,0 L8,4 L6,4 L4,2 L2,4Z M0,8 L4,4 L8,8 L6,8 L4,6 L2,8Z
    </Geometry>
    
    <Geometry x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type xpbar:XPlorerResourceKeys},ResourceId=XPlorerSectionHeaderExpandArrows}">
        M0,1 L4,5 L8,1 L6,1 L4,3 L2,1Z M0,5 L4,9 L8,5 L6,5 L4,7 L2,5Z
    </Geometry>


    <!-- ==================== -->
    <!-- = XPlorerBar style = -->
    <!-- ==================== -->
    <Style x:Key="{x:Type xpbar:XPlorerBar}" TargetType="{x:Type xpbar:XPlorerBar}">
        <Setter Property="FontFamily" Value="Trebuchet MS"/>
        <Setter Property="Padding" Value="12,12,12,0"/>
        <Setter Property="Width" Value="230"/>
        <Setter Property="Background" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerBarBackgroundBrushKey}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type xpbar:XPlorerBar}">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="False" FontFamily="{TemplateBinding FontFamily}" Padding="{TemplateBinding Padding}">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ======================== -->
    <!-- = XPlorerSection style = -->
    <!-- ======================== -->
    <Style TargetType="{x:Type xpbar:XPlorerSection}">
        <Setter Property="Background" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionContentBackgroundBrushKey}}"/>
        <Setter Property="Foreground" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionContentForegroundBrushKey}}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionContentBorderBrushKey}}"/>
        <Setter Property="BorderThickness" Value="1,0,1,1"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Margin" Value="0,0,0,15"/>
        <Setter Property="ExpandOrCollapseDuration" Value="300.0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type xpbar:XPlorerSection}">
                    <StackPanel Orientation="Vertical">
                        <!-- Header -->
                        <ToggleButton x:Name="PART_HeaderSite"
                                      Content="{TemplateBinding Header}" 
                                      Style="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionHeaderStyleKey}}"/>
                        <!-- Content -->
                        <xpbar:XPandableDecorator x:Name="PART_ContentSite">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </xpbar:XPandableDecorator>

                    </StackPanel>
                    
                    <ControlTemplate.Triggers>

                        <!-- IsPrimary = true -->
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsPrimary}" Value="true">
                            <Setter Property="Background" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionPrimaryContentBackgroundBrushKey}}"/>
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionPrimaryContentForegroundBrushKey}}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionPrimaryContentBorderBrushKey}}"/>
                        </DataTrigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- =============================== -->
    <!-- = XPlorerSection header style = -->
    <!-- =============================== -->
    <Style x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type xpbar:XPlorerResourceKeys},ResourceId=XPlorerSectionHeaderStyle}" 
           TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionHeaderBackgroundBrushKey}}"/>
        <Setter Property="Foreground" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionHeaderForegroundBrushKey}}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">

                    <Grid>
                        <Border x:Name="toggleBorder" 
                                Background="{TemplateBinding Background}" 
                                Height="23" VerticalAlignment="Bottom">
                            <DockPanel LastChildFill="True">
                                <!-- Expand/Collapse button -->
                                <Grid DockPanel.Dock="Right">
                                    <!-- The two borders below create the 3D effect when the mouse is over the header -->
                                    <Border x:Name="buttonTopLeftBorder" Height="16" Width="17" Margin="0,4,6,3" 
                                        BorderThickness="1,1,0,0" BorderBrush="Transparent">
                                        <Border x:Name="buttonBottomRightBorder" Height="15" Width="16" 
                                            BorderThickness="0,0,1,1" BorderBrush="Transparent">
                                            <!-- Arrows -->
                                            <Path x:Name="buttonArrows" SnapsToDevicePixels="True"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"                                              
                                              Data="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionHeaderExpandArrowsKey}}" 
                                              Fill="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionHeaderForegroundBrushKey}}"/>
                                        </Border>
                                    </Border>
                                </Grid>
                                <!-- Header text -->
                                <ContentPresenter x:Name="contentSite" 
                                                  Content="{TemplateBinding Content}" Margin="35,6,10,0"
                                                  HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </DockPanel>
                        </Border>
                        <!-- Header image -->
                        <Image x:Name="headerImage" 
                           Width="32" Height="32" Margin="1,0,0,0" Visibility="Visible"
                           HorizontalAlignment="Left" VerticalAlignment="Bottom"
                           Source="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type xpbar:XPlorerSection}}, Path=HeaderImage}"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        
                        <!-- IsMouseOver = true -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="buttonTopLeftBorder" Property="BorderBrush" Value="#ffffff"/>
                            <Setter TargetName="buttonBottomRightBorder" Property="BorderBrush" Value="#808080"/>
                        </Trigger>
                        
                        <!-- IsChecked = true -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="buttonArrows" Property="Data" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionHeaderCollapseArrowsKey}}"/>
                        </Trigger>
                        
                        <!-- IsPrimary = true -->
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsPrimary}" Value="true">
                            <Setter Property="Background" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionPrimaryHeaderBackgroundBrushKey}}"/>
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionPrimaryHeaderForegroundBrushKey}}"/>
                            <Setter TargetName="buttonArrows" Property="Fill" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionPrimaryHeaderForegroundBrushKey}}"/>
                            <Setter TargetName="toggleBorder" Property="Height" Value="25"/>
                        </DataTrigger>
                        
                        <!-- There is no header image -->
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HeaderImage}" Value="{x:Null}">
                            <Setter TargetName="headerImage" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="contentSite" Property="Margin" Value="12,6,10,0"/>
                        </DataTrigger>
                        
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <!-- ===================== -->
    <!-- = XPlorerItem style = -->
    <!-- ===================== -->
    <Style x:Key="{x:Type xpbar:XPlorerItem}" TargetType="{x:Type xpbar:XPlorerItem}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type xpbar:XPlorerItem}">
                    
                    <DockPanel LastChildFill="True">
                        <!-- item image -->
                        <Image x:Name="itemImage" Margin="3,2,0,2" DockPanel.Dock="Left" Source="{TemplateBinding ItemImage}" Width="16" Height="16"/>
                        <!-- item text -->
                        <TextBlock x:Name="itemText" 
                                   DockPanel.Dock="Left" Margin="7,0,0,0" VerticalAlignment="Center"
                                   Text="{TemplateBinding ItemText}" TextWrapping="Wrap"/>
                    </DockPanel>
                    
                    <ControlTemplate.Triggers>
                        
                        <!-- if there is no image -->
                        <Trigger Property="ItemImage" Value="{x:Null}">
                            <Setter TargetName="itemImage" Property="Width" Value="0"/>
                            <Setter TargetName="itemText" Property="Margin" Value="3,0,0,0"/>
                        </Trigger>
                        
                        <!-- IsMouseOver = true -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="itemText" Property="TextDecorations" Value="Underline"/>
                            <Setter TargetName="itemText" Property="Foreground" Value="{DynamicResource {x:Static xpbar:XPlorerResourceKeys.XPlorerSectionContentHoverForegroundBrushKey}}"/>
                        </Trigger>
                        
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    

    <!-- ================ -->
    <!-- = Border style = -->
    <!-- ================ -->

    <!-- Avoids the blurry edges around borders -->
    <Style TargetType="{x:Type Border}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

</ResourceDictionary>