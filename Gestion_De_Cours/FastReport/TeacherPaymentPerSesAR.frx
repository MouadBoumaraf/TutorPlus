      <Column Name="Text" DataType="System.String"/>
      <Column Name="Rtl" DataType="System.Boolean" BindableControl="CheckBox"/>
      <Column Name="Active" DataType="System.Boolean" BindableControl="CheckBox"/>
    </TableDataSource>
    <BusinessObjectDataSource Name="Categories BusinessObject" ReferenceName="Categories BusinessObject" DataType="null" Enabled="true">
      <Column Name="Name" DataType="System.String"/>
      <Column Name="Description" DataType="System.String"/>
      <BusinessObjectDataSource Name="Products1" Alias="Products" Enabled="false" DataType="null" PropName="Products"/>
    </BusinessObjectDataSource>
