      <Column Name="ID" DataType="System.Int32"/>
      <Column Name="Tses" DataType="System.Int32"/>
      <Column Name="SPrice" DataType="System.Int32"/>
      <Column Name="TPrice" DataType="System.Int32"/>
      <Column Name="SuPrice" DataType="System.Int32"/>
      <Column Name="Date1" DataType="System.String"/>
      <Column Name="Date2" DataType="System.String"/>
    </TableDataSource>
    <TableDataSource Name="DataGeneral" ReferenceName="Data.DataGeneral" DataType="System.Int32" Enabled="true">
      <Column Name="TName" DataType="System.String"/>
