<UserControl
    x:Class="Gestion_De_Cours.UControl.AllAttendance"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:local="clr-namespace:Gestion_De_Cours.UControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    dx:ThemeManager.ThemeName="None"
    PreviewKeyDown="UserControl_PreviewKeyDown"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <FontFamily x:Key="FontLabel">pack://application:,,,/Fonts/#Droid Arabic Kufi</FontFamily>
                </ResourceDictionary>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Name="Row1" Height="80" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel
            Grid.Row="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
            <StackPanel
                Grid.Row="0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">

                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">

                    <Button
                        Grid.Row="2"
                        Grid.Column="0"
                        Width="100"
                        Height="30"
                        Margin="0,0,50,0"
                        HorizontalAlignment="Left"
                        Background="#EF5350"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="15"
                        BorderThickness="0"
                        Padding="0"
                        Click="Button_Click_Absent"
                        Content="{DynamicResource Absent}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button
                        Grid.Row="2"
                        Grid.Column="1"
                        Width="100"
                        Height="30"
                        HorizontalAlignment="Left"
                        Background="#66BB6A"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="15"
                        BorderThickness="0"
                        Padding="0"
                        Click="Button_Click_Present"
                        Content="{DynamicResource Present}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Label
                    Name="LBSearch"
                    Width="60"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Right"
                    Content="{DynamicResource SearchLB}"
                    FontSize="15" />
                <TextBox
                    Name="TBSearch"
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="4"
                    Width="150"
                    Height="30"
                    Margin="0,0,10,0"
                    HorizontalAlignment="Left"
                    FontSize="15"
                    PreviewKeyDown="TBSearch_PreviewKeyDown"
                    TextChanged="TextBox_TextChanged" />
                <Label
                    Width="60"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Right"
                    Content="{DynamicResource GroupLB}"
                    FontSize="15" />
                <dxe:ComboBoxEdit
                    Name="CustomComboBox"
                    Width="140"
                    Height="36"
                    Margin="0,0,10,0"
                    FontSize="15"
                    FontWeight="SemiBold"
                    ShowBorder="True"
                    PopupWidth="220"
                    dx:ThemeManager.ThemeName="Office2019Colorful"
                    EditValueChanged="CustomComboBox_SelectionChanged"
                    Visibility="Visible">
                    <dxe:ComboBoxEdit.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,2">
                                <CheckBox
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Width="20"
                                    Height="20"
                                    IsChecked="{Binding Checked}"
                                    Checked="CheckBox_Checked"
                                    Unchecked="CheckBox_Unchecked">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="CheckBox">
                                                        <Grid>
                                                            <Ellipse Width="20" Height="20" Fill="#FFF" Stroke="#CCC"/>
                                                            <Path x:Name="CheckMark" Data="M4,10 L9,15 L16,6"
                                                                  Stroke="#4CAF50" StrokeThickness="2"
                                                                  Visibility="Collapsed"/>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                                <TextBlock
                                    Margin="0,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    Text="{Binding Name}" />
                            </StackPanel>
                        </DataTemplate>
                    </dxe:ComboBoxEdit.ItemTemplate>
                </dxe:ComboBoxEdit>
                <Button
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Width="70"
                    Height="70"
                    Margin="20,0,0,0"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="Button_Click_ChangeStudents"
                    Visibility="Visible">
                    <StackPanel>
                        <Image
                            Width="32"
                            Height="32"
                            Source="/Images/Change256.png" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="9"
                            FontWeight="Bold"
                            Text="{DynamicResource ChangeGroup}" />
                    </StackPanel>
                </Button>
                <Button
                    Name="BtnExtraSes"
                    Width="70"
                    Height="70"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="BtnExtraSes_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <!--  Image  -->
                        <Image
                            Width="32"
                            Height="32"
                            Source="/Images/AddSign.png" />
                        <!--  Text  -->
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="9"
                            FontWeight="Bold"
                            Text="{DynamicResource ExtraSession}" />
                    </StackPanel>
                </Button>
                <Button
                    Name="BtnRefresh"
                    Width="70"
                    Height="70"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="BtnRefresh_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <!--  Image  -->
                        <Image
                            Width="32"
                            Height="32"
                            Source="/Images/refresh.png" />
                        <!--  Text  -->
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="9"
                            FontWeight="Bold"
                            Text="{DynamicResource Refresh}" />
                    </StackPanel>
                </Button>
                <Label
                    Width="60"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Right"
                    Content="{DynamicResource DateLB}"
                    FontSize="15" />
                <DatePicker
                    Name="DPTodayDate"
                    Width="150"
                    VerticalAlignment="Center"
                    Language="fr-FR"
                    SelectedDateChanged="DPTodayDate_SelectedDateChanged" />
            </StackPanel>

            <StackPanel
                Margin="0,10,0,10"
                HorizontalAlignment="Center"
                Orientation="Horizontal" />
        </StackPanel>

        <Border
            Name="bordermain"
            Grid.Row="1"
            BorderBrush="Black"
            BorderThickness="3">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <StackPanel
                    Name="SPAttendance"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    CanHorizontallyScroll="True"
                    Orientation="Horizontal" />
            </ScrollViewer>
        </Border>

        <Popup
            Name="MyPopup"
            IsOpen="False"
            Opened="MyPopup_Opened"
            Placement="Center">
            <!--  Content of the Popup  -->
            <Border
                Width="200"
                Height="100"
                Background="White">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        Name="PopupText"
                        FontSize="18"
                        Text="This is a popup!" />
                    <!--  Add other content to your popup here  -->
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
