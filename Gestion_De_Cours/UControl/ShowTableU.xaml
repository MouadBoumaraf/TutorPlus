<UserControl
    x:Class="Gestion_De_Cours.UControl.ShowTableU"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:local="clr-namespace:Gestion_De_Cours.UControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rs="clr-namespace:Gestion_De_Cours.Properties"
    d:DesignHeight="400"
    d:DesignWidth="1200"
    dx:ThemeManager.ThemeName="None"
    KeyDown="Window_KeyDown"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="150" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Name="row1" Height="0" />
            <RowDefinition Name="row4" Height="50" />
            <RowDefinition Name="row3" Height="50" />
            <RowDefinition Name="row2" Height="40" />
            <RowDefinition Height="5*" />
        </Grid.RowDefinitions>

        <Expander
            Grid.ColumnSpan="6"
            VerticalContentAlignment="Top"
            Collapsed="Expander_Collapsed"
            Expanded="Expander_Expanded"
            FontSize="20"
            IsExpanded="False"
            Visibility="Visible">
            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">

                        <Label
                            Width="90"
                            HorizontalContentAlignment="Right"
                            Content="{DynamicResource FirstNameLB}"
                            FontSize="15" />
                        <TextBox
                            Name="TBStudentFName"
                            Width="100"
                            Height="30"
                            VerticalContentAlignment="Center"
                            FontSize="15"
                            PreviewKeyDown="TBStudentFName_PreviewKeyDown" />
                        <Label
                            Width="90"
                            HorizontalContentAlignment="Right"
                            Content="{DynamicResource LastNameLB}"
                            FontSize="15" />
                        <TextBox
                            Name="TBStudentLName"
                            Width="100"
                            Height="30"
                            VerticalContentAlignment="Center"
                            FontSize="15"
                            PreviewKeyDown="TBStudentLName_PreviewKeyDown" />
                        <Label
                            Width="90"
                            HorizontalContentAlignment="Right"
                            Content="{DynamicResource Number1}"
                            FontSize="15" />
                        <TextBox
                            Name="TBStudentNumber1"
                            Width="100"
                            Height="30"
                            VerticalContentAlignment="Center"
                            FontSize="15"
                            PreviewKeyDown="TBStudentNumber1_PreviewKeyDown" />
                        <Label
                            Width="90"
                            HorizontalContentAlignment="Right"
                            Content="{DynamicResource BirthDateLB}"
                            FontSize="15" />
                        <DatePicker
                            Name="DPStudent"
                            Width="100"
                            Height="30"
                            VerticalContentAlignment="Center"
                            FontSize="15"
                            Language="fr-FR"
                            PreviewKeyDown="DPStudent_PreviewKeyDown" />
                        <Label
                            Width="90"
                            HorizontalContentAlignment="Right"
                            Content="{DynamicResource GenderLB}"
                            FontSize="15" />
                        <ComboBox
                            Name="CBStudentGender"
                            Grid.Row="6"
                            Grid.Column="0"
                            Width="100"
                            Height="30"
                            FontSize="15"
                            PreviewKeyDown="CBStudentGender_PreviewKeyDown">
                            <ComboBoxItem Content="{DynamicResource Male}" />
                            <ComboBoxItem Content="{DynamicResource Female}" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">

                        <Label
                            Width="90"
                            HorizontalContentAlignment="Right"
                            Content="{DynamicResource LevelLB}"
                            FontSize="15" />
                        <ComboBox
                            Name="CBStudentLevel"
                            Width="100"
                            Height="30"
                            VerticalContentAlignment="Center"
                            DisplayMemberPath="Level"
                            FontSize="15"
                            ItemsSource="{Binding}"
                            PreviewKeyDown="CBStudentLevel_PreviewKeyDown"
                            SelectedValuePath="ID"
                            SelectionChanged="CBStudentLevel_SelectionChanged" />
                        <Label
                            Width="90"
                            HorizontalContentAlignment="Right"
                            Content="{DynamicResource YearLB}"
                            FontSize="15" />
                        <ComboBox
                            Name="CBStudentYear"
                            Width="100"
                            Height="30"
                            VerticalContentAlignment="Center"
                            DisplayMemberPath="Year"
                            FontSize="15"
                            ItemsSource="{Binding}"
                            PreviewKeyDown="CBStudentYear_PreviewKeyDown"
                            SelectedValuePath="ID"
                            SelectionChanged="CBStudentYear_SelectionChanged" />
                        <Label
                            Width="90"
                            HorizontalContentAlignment="Right"
                            Content="{DynamicResource SpecialityLB}"
                            FontSize="15" />
                        <ComboBox
                            Name="CBStudentSpec"
                            Width="100"
                            Height="30"
                            VerticalContentAlignment="Center"
                            DisplayMemberPath="Speciality"
                            FontSize="15"
                            ItemsSource="{Binding}"
                            PreviewKeyDown="CBStudentSpec_PreviewKeyDown"
                            SelectedValuePath="ID"
                            SelectionChanged="CBStudentSpec_SelectionChanged" />
                        <Label
                            Width="90"
                            HorizontalContentAlignment="Right"
                            Content="{DynamicResource FeesLB}"
                            FontSize="15" />
                        <ComboBox
                            Name="CBStudentInsc"
                            Width="100"
                            Height="30"
                            VerticalContentAlignment="Center"
                            FontSize="15"
                            PreviewKeyDown="CBStudentInsc_PreviewKeyDown">
                            <ComboBoxItem Content="{DynamicResource Paid}" Foreground="Green" />
                            <ComboBoxItem Content="{DynamicResource Didntpay}" Foreground="Red" />
                            <ComboBoxItem Content="{DynamicResource DoesntPay}" />
                        </ComboBox>
                        <Label
                            Width="90"
                            HorizontalContentAlignment="Right"
                            Content="{DynamicResource ClassLB}"
                            FontSize="15" />
                        <ComboBox
                            Name="CBStudentClass"
                            Width="100"
                            Height="30"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            PreviewKeyDown="CBStudentClass_PreviewKeyDown"
                            SelectionChanged="ComboBox_SelectionChanged">

                            <ComboBoxItem Height="200">
                                <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                                    <TreeView
                                        Name="treeView"
                                        Width="190"
                                        FontSize="15"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="IsExpanded" Value="True" />
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                        <TreeView.ItemTemplate>
                                            <HierarchicalDataTemplate ItemsSource="{Binding ClassToGroup}">
                                                <TextBlock Text="{Binding ClassName}" />
                                                <HierarchicalDataTemplate.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <CheckBox
                                                                VerticalContentAlignment="Center"
                                                                Checked="CheckBox_TreeView_Checked"
                                                                IsChecked="{Binding IsChecked}"
                                                                Unchecked="CheckBox_TreeView_Unchecked">
                                                                <Label Content="{Binding GroupName}" />
                                                            </CheckBox>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </HierarchicalDataTemplate.ItemTemplate>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </ScrollViewer>
                            </ComboBoxItem>

                        </ComboBox>
                    </StackPanel>

                </StackPanel>
                <Button
                    Name="BtnAddStudent"
                    Width="80"
                    Height="25"
                    Margin="10,0,0,10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="BtnAddStudent_Click"
                    Content="+"
                    FontSize="15" />
            </StackPanel>
        </Expander>
        <StackPanel
            Grid.Row="2"
            Grid.ColumnSpan="6"
            VerticalAlignment="Center">
            <StackPanel
                Grid.Row="2"
                Grid.ColumnSpan="5"
                Orientation="Horizontal">
                <Label
                    Name="LBSearch"
                    Width="60"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Right"
                    Content="{DynamicResource SearchLB}"
                    FontSize="15" />
                <TextBox
                    Name="TBSearch"
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="4"
                    Width="150"
                    Height="30"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Left"
                    FontSize="15"
                    TextChanged="TextBox_TextChanged" />
                <ComboBox
                    Name="CBGender"
                    Width="90"
                    Height="30"
                    Margin="10,0,10,0"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    SelectionChanged="CB_SelectionChanged">
                    <ComboBoxItem Content="{DynamicResource Gender--}" />
                    <ComboBoxItem Content="{DynamicResource Male}" />
                    <ComboBoxItem Content="{DynamicResource Female}" />
                </ComboBox>
                <ComboBox
                    Name="CBClass"
                    Width="150"
                    Height="30"
                    Margin="10,0,0,0"
                    DisplayMemberPath="CName"
                    FontSize="15"
                    ItemsSource="{Binding}"
                    SelectedValuePath="ID"
                    SelectionChanged="CB_SelectionChanged"
                    Visibility="Collapsed" />
                <ComboBox
                    Name="CBLevel"
                    Width="90"
                    Height="30"
                    Margin="0,0,0,0"
                    VerticalContentAlignment="Center"
                    DisplayMemberPath="Level"
                    FontSize="15"
                    ItemsSource="{Binding}"
                    SelectedValuePath="ID"
                    SelectionChanged="CBLevel_SelectionChanged" />
                <ComboBox
                    Name="CBYear"
                    Width="90"
                    Height="30"
                    Margin="5,0,5,0"
                    DisplayMemberPath="Year"
                    FontSize="15"
                    ItemsSource="{Binding}"
                    SelectedValuePath="ID"
                    SelectionChanged="CBYear_SelectionChanged" />
                <ComboBox
                    Name="CBSpec"
                    Width="90"
                    Height="30"
                    Margin="5,0,5,0"
                    DisplayMemberPath="Speciality"
                    ItemsSource="{Binding}"
                    SelectedValuePath="ID"
                    SelectionChanged="CB_SelectionChanged" />
                <ComboBox
                    Name="CustomComboBox"
                    Width="120"
                    Height="30"
                    SelectionChanged="CustomComboBox_SelectionChanged"
                    Visibility="Visible">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Name="ItemTextBlock"
                                    Margin="0,0,5,0"
                                    Text="{Binding Text}" />
                                <CheckBox
                                    Name="checkBox"
                                    Checked="CheckBox_Checked"
                                    IsChecked="{Binding IsChecked}"
                                    Unchecked="CheckBox_Unchecked" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Label
                    Name="LBType"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Right"
                    Content="{DynamicResource TypeLB}"
                    FontSize="15"
                    Visibility="Collapsed" />
                <ComboBox
                    Name="CBType"
                    Width="150"
                    Height="30"
                    VerticalAlignment="Center"
                    FontSize="15"
                    SelectionChanged="CB_SelectionChanged"
                    Visibility="Collapsed">
                    <ComboBoxItem Content="{DynamicResource Student}" />
                    <ComboBoxItem Content="{DynamicResource Teacher}" />
                    <ComboBoxItem Content="{DynamicResource Worker}" />
                    <ComboBoxItem Content="{DynamicResource Class}" />
                    <ComboBoxItem Content="{DynamicResource Attendance}" />
                    <ComboBoxItem Content="{DynamicResource TeacherPayment}" />
                    <ComboBoxItem Content="{DynamicResource StudentPayment}" />
                    <ComboBoxItem Content="{DynamicResource CashRegister}" />
                    <ComboBoxItem Content="{DynamicResource Discounts}" />
                    <ComboBoxItem Content="{DynamicResource Justification}" />
                </ComboBox>
                <Label
                    Name="LBTypeAction"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Right"
                    Content="{DynamicResource ActionTypeLB}"
                    FontSize="15"
                    Visibility="Collapsed" />
                <ComboBox
                    Name="CBTypeAction"
                    Width="150"
                    Height="30"
                    FontSize="15"
                    SelectionChanged="CB_SelectionChanged"
                    Visibility="Collapsed">
                    <ComboBoxItem Content="{DynamicResource Add}" />
                    <ComboBoxItem Content="{DynamicResource Delete}" />
                    <ComboBoxItem Content="{DynamicResource Update}" />
                </ComboBox>
                <Label
                    Name="LBdate"
                    Width="70"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Right"
                    Content="{DynamicResource DateLB}"
                    FontSize="15"
                    Visibility="Collapsed" />
                <DatePicker
                    Name="Date"
                    Width="150"
                    Height="30"
                    VerticalAlignment="Center"
                    Language="fr-FR"
                    SelectedDateChanged="Date_SelectedDateChanged"
                    Visibility="Collapsed" />

                <StackPanel
                    Name="SPG1"
                    Orientation="Horizontal"
                    Visibility="Collapsed" />
            </StackPanel>

        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Grid.ColumnSpan="4"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Orientation="Horizontal">
            <Button
                Width="50"
                Height="50"
                Margin="5,0,5,0"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_Add">
                <Image Source="/Images/addsign.png" />
            </Button>
            <Button
                Width="50"
                Height="50"
                Margin="5,0,5,0"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_Delete">
                <Image Source="/Images/deleteicon.png" />
            </Button>
            <Button
                Width="50"
                Height="50"
                Margin="5,0,5,0"
                Background="Transparent"
                BorderBrush="Transparent"
                Visibility="Collapsed">
                <Image Source="/Images/archive.png" />
            </Button>
            <Button
                Width="50"
                Height="50"
                Margin="5,0,5,0"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_Import">
                <Image Source="/Images/Excel.png" />
            </Button>

            <Button
                Name="BtnIMG1"
                Width="50"
                Height="50"
                Margin="5,0,5,0"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_PrintStudentInfo">
                <Image Source="/Images/resume.png" />
            </Button>

            <Button
                Name="BtnIMG2"
                Width="50"
                Height="50"
                Margin="5,0,5,0"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_PrintClassPayments">
                <Image Source="/Images/paymentlist.png" />
            </Button>

            <Button
                Name="BtnIMG3"
                Width="50"
                Height="50"
                Margin="5,0,5,0"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_PrintHistory">
                <Image Source="/Images/Attendance.png" />
            </Button>

            <Button
                Name="BtnIMG4"
                Width="50"
                Height="50"
                Margin="5,0,5,0"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_PrintBarCode">
                <Image Source="/Images/printing.png" />
            </Button>
        </StackPanel>
        <StackPanel
            Grid.Row="1"
            Grid.RowSpan="3"
            Grid.Column="3"
            Grid.ColumnSpan="2">
            <StackPanel
                Name="SPImage"
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="3"
                Grid.ColumnSpan="2"
                Orientation="Horizontal">
                <Border
                    Width="75"
                    Height="75"
                    Margin="0,5,0,0"
                    VerticalAlignment="Top"
                    BorderBrush="Black"
                    BorderThickness="2">
                    <Image
                        Name="Pic"
                        Width="75"
                        Height="75"
                        VerticalAlignment="Top"
                        Stretch="UniformToFill" />
                </Border>
                <StackPanel>
                    <TextBlock
                        Name="TBName"
                        Margin="5,0,0,0"
                        VerticalAlignment="Top"
                        FontSize="12" />
                    <TextBlock
                        Name="TBNumber"
                        Margin="5,0,0,0"
                        VerticalAlignment="Top"
                        FontSize="12" />
                    <TextBlock
                        Name="TBYear"
                        Margin="5,0,0,0"
                        VerticalAlignment="Top"
                        FontSize="12" />
                </StackPanel>

            </StackPanel>
        </StackPanel>
        <StackPanel
            Name="SPStudentTotal"
            Grid.Row="1"
            Grid.RowSpan="3"
            Grid.Column="4"
            HorizontalAlignment="Center"
            Orientation="Vertical"
            Visibility="Visible">
            <Label
                VerticalContentAlignment="Center"
                Content="{DynamicResource StudentTotal}"
                FontSize="16" />
            <Border
                Width="100"
                Height="35"
                Margin="0,0,0,0"
                BorderBrush="Black"
                BorderThickness="2">
                <TextBlock
                    Name="StudentAmmount"
                    Width="100"
                    VerticalAlignment="Center"
                    FontSize="20"
                    TextAlignment="Center" />
            </Border>
        </StackPanel>

        <ListView
            x:Name="DGUC"
            Grid.Row="3"
            Grid.RowSpan="2"
            Grid.ColumnSpan="5"
            MinHeight="500"
            Margin="10"
            FontSize="15"
            IsSynchronizedWithCurrentItem="True"
            ItemsSource="{Binding IsAsync=True}"
            MouseDoubleClick="ListviewUC_MouseDoubleClick"
            SelectionChanged="DGUC_SelectionChanged"
            Visibility="Visible">
            <ListView.Resources>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontSize" Value="15"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F1F8E9"/>
                            <!-- Light green hover -->
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#A5D6A7"/>
                            <!-- Softer green when selected -->
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.Resources>
            <ListView.View>
                <GridView>
                  
                <!-- Add additional columns as needed, mapping from DataGrid columns -->
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
