<UserControl
    x:Class="Gestion_De_Cours.UControl.SettingEcole"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:local="clr-namespace:Gestion_De_Cours.UControl"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rs="clr-namespace:Gestion_De_Cours.Properties"
    d:DesignHeight="700"
    d:DesignWidth="1200"
    dx:ThemeManager.ThemeName="None"
    FontSize="15"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="320" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <StackPanel
            Grid.ColumnSpan="2"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Name="BtnSave"
                Grid.ColumnSpan="2"
                Width="50"
                Height="50"
                Margin="0,0,10,0"
                HorizontalAlignment="Center"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="BtnSave_Click">
                <Image Name="IMGSave" Source="/Images/tick.png" />
            </Button>
            <Button
                Name="BtnCancel"
                Grid.ColumnSpan="2"
                Width="50"
                Height="50"
                Margin="10,0,0,0"
                HorizontalAlignment="Center"
                Background="Transparent"
                BorderBrush="Transparent">
                <Image Name="IMGCancel" Source="/Images/Cancel.jpg" />
            </Button>
        </StackPanel>
        <TextBlock
            Name="TBlockEcole"
            Grid.ColumnSpan="1"
            Width="400"
            HorizontalAlignment="Left"
            FontSize="25" />
        <GroupBox
            Grid.Row="1"
            Grid.RowSpan="1"
            Grid.ColumnSpan="1"
            BorderBrush="#a5bd84"
            BorderThickness="2">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <Image
                        Name="IMGEcole"
                        Width="25"
                        Height="25"
                        Source="/Images/School.png" />

                    <Label Content="{DynamicResource EcoleInfo}" FontSize="15" />
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                    <RowDefinition Height="35" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="255" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Label
                        Width="140"
                        Content="{DynamicResource NameFRLB}"
                        FontSize="15" />
                    <TextBox
                        Name="TBNameFR"
                        Width="200"
                        Height="25"
                        LostFocus="TextBox_LostFocus" />
                </StackPanel>
                <StackPanel
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Label
                        Width="140"
                        Content="{DynamicResource NameARLB}"
                        FontSize="15" />
                    <TextBox
                        Name="TBNameAR"
                        Width="200"
                        Height="25"
                        LostFocus="TextBox_LostFocus" />
                </StackPanel>
                <StackPanel
                    Grid.Row="2"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Label
                        Width="140"
                        Content="{DynamicResource AdressLB}"
                        FontSize="15" />
                    <TextBox
                        Name="TBAdress1"
                        Width="200"
                        Height="25"
                        LostFocus="TextBox_LostFocus" />
                </StackPanel>
                <StackPanel
                    Grid.Row="3"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Label
                        Width="140"
                        Content="{DynamicResource Adress2LB}"
                        FontSize="15" />
                    <TextBox
                        Name="TBAdress2"
                        Width="200"
                        Height="25"
                        LostFocus="TextBox_LostFocus" />
                </StackPanel>
                <StackPanel
                    Grid.Row="4"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Label
                        Width="140"
                        Content="{DynamicResource NumberLB}"
                        FontSize="15" />
                    <TextBox
                        Name="TBNumber1"
                        Width="200"
                        Height="25"
                        LostFocus="TextBox_LostFocus" />
                </StackPanel>
                <StackPanel
                    Grid.Row="5"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Label
                        Width="140"
                        Content="{DynamicResource Number2LB}"
                        FontSize="15" />
                    <TextBox
                        Name="TBNumber2"
                        Width="200"
                        Height="25"
                        LostFocus="TextBox_LostFocus" />
                </StackPanel>
                <StackPanel
                    Grid.Row="6"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <Label
                        Width="140"
                        Content="{DynamicResource CCPLB}"
                        FontSize="15" />
                    <TextBox
                        Name="TBCCP"
                        Width="200"
                        Height="25"
                        LostFocus="TextBox_LostFocus" />
                </StackPanel>
                <StackPanel
                    Grid.Row="7"
                    Grid.ColumnSpan="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Visibility="Collapsed">
                    <Label
                        Width="140"
                        Content="{DynamicResource FaxLB}"
                        FontSize="15" />
                    <TextBox
                        Name="TBFax"
                        Width="200"
                        Height="25"
                        LostFocus="TextBox_LostFocus" />
                </StackPanel>
                <Button
                    Grid.Row="5"
                    Grid.Column="1"
                    Width="75"
                    Margin="0,0,35,0"
                    HorizontalAlignment="Right"
                    Click="Button_Click"
                    Content="{DynamicResource Insert}" />
                <GroupBox
                    Grid.Row="0"
                    Grid.RowSpan="5"
                    Grid.Column="1"
                    Width="150"
                    Height="150"
                    HorizontalAlignment="Right"
                    BorderBrush="Black"
                    BorderThickness="2"
                    Header="{DynamicResource Logo}">
                    <Image
                        Name="EcolePic"
                        Grid.Row="0"
                        Grid.RowSpan="4"
                        Grid.Column="1" />
                </GroupBox>
            </Grid>
        </GroupBox>
        <StackPanel Grid.Row="1" Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="320" />

                </Grid.RowDefinitions>
                <GroupBox
                    Grid.Row="0"
                    Grid.RowSpan="1"
                    Grid.Column="1"
                    BorderBrush="#a5bd84"
                    BorderThickness="2">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <Image
                                Name="IMGPayment"
                                Width="25"
                                Height="25"
                                Source="/Images/PaymentSettings.png" />
                            <Label Content="{DynamicResource Payment}" FontSize="15" />
                        </StackPanel>
                    </GroupBox.Header>
                    <StackPanel
                        Grid.Row="0"
                        Grid.Column="1"
                        Orientation="Vertical">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <StackPanel
                                Grid.Row="0"
                                Grid.ColumnSpan="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Label
                                    Width="120"
                                    Content="{DynamicResource InscFeesLB}"
                                    FontSize="15" />
                                <ComboBox
                                    Name="CBInscLevel"
                                    Width="80"
                                    Height="25"
                                    Margin="0,0,10,0"
                                    DisplayMemberPath="Level"
                                    FontSize="15"
                                    SelectedValuePath="ID"
                                    SelectionChanged="ComboBox_SelectionChanged_1" />
                                <TextBox
                                    Name="TBFees"
                                    Width="150"
                                    Height="25"
                                    LostFocus="TextBox_LostFocus" />
                                <Button
                                    Width="50"
                                    Height="25"
                                    Margin="10,0,0,0"
                                    Click="Button_Click_2"
                                    Content="+" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Label
                                    Grid.Row="1"
                                    Content="{DynamicResource ChargeStudent}"
                                    FontSize="15" />
                                <RadioButton
                                    Name="YesAbs"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Yes}" />
                                <RadioButton
                                    Name="NoAbs"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource No}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="2"
                                Grid.ColumnSpan="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Label
                                    Grid.Row="1"
                                    Content="{DynamicResource TPaymentDepS}"
                                    FontSize="15" />
                                <RadioButton
                                    Name="YesClass"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Yes}" />
                                <RadioButton
                                    Name="NoClass"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource No}" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="3"
                                Grid.ColumnSpan="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                                <Label
                                    Grid.Row="1"
                                    Content="{DynamicResource PaymentPerMonth}"
                                    FontSize="15" />
                                <RadioButton
                                    Name="YesMonthes"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Yes}" />
                                <RadioButton
                                    Name="NoMonthes"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource No}" />
                                <RadioButton
                                    Name="CustomMonthes"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Custom}" />
                                <Button
                                    Width="40"
                                    Height=" 20"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    VerticalContentAlignment="Top"
                                    Click="Button_Click_3"
                                    Content="+" />
                            </StackPanel>
                            <StackPanel
                                Grid.Row="4"
                                Grid.ColumnSpan="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Visibility="Collapsed">
                                <Label
                                    Grid.Row="1"
                                    Content="{DynamicResource CalcMethod}"
                                    FontSize="15" />
                                <RadioButton
                                    Name="YesCalcMethod"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource Yes}" />
                                <RadioButton
                                    Name="NoCalcMethod"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource No}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

            </Grid>
        </StackPanel>
        <DockPanel
            Grid.Row="2"
            Grid.RowSpan="1"
            Grid.ColumnSpan="2"
            Background="Transparent">
            <TabControl
                Grid.Row="1"
                Background="Transparent"
                BorderBrush="#a5bd84"
                BorderThickness="2"
                TabStripPlacement="Top">
                <TabItem Header="{DynamicResource Level}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Label
                                VerticalAlignment="Center"
                                Content="{DynamicResource LevelNameLB}"
                                FontSize="15" />
                            <Label
                                VerticalAlignment="Center"
                                Content="{DynamicResource HaveSpec}"
                                FontSize="10" />
                            <Label
                                Margin="0,0,0,0"
                                VerticalAlignment="Center"
                                Content=":"
                                FontSize="20" />
                            <StackPanel
                                Name="IsSpec"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Visibility="Visible">
                                <RadioButton
                                    Name="Yes"
                                    Content="{DynamicResource Yes}"
                                    FontSize="12" />
                                <RadioButton
                                    Name="No"
                                    Content="{DynamicResource No}"
                                    FontSize="12" />
                            </StackPanel>
                            <TextBox
                                Name="LevelTB"
                                Width="150"
                                Height="30" />
                            <Button
                                Width="40"
                                Height="40"
                                Margin="5,0,5,0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="Button_Click_Level">
                                <Image Source="/Images/addsign.png" />
                            </Button>

                        </StackPanel>
                        <Button
                            Grid.ColumnSpan="2"
                            Width="50"
                            Height="50"
                            Margin="0,0,20,0"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="Button_Click_Import">
                            <Image Source="/Images/Import.png" />
                        </Button>
                        <DataGrid
                            Name="DGLevel"
                            Grid.Row="1"
                            Grid.RowSpan="2"
                            MinHeight="230"
                            MaxHeight="230"
                            Margin="0,5,0,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            AutoGenerateColumns="False"
                            FontSize="15"
                            IsReadOnly="True"
                            ItemsSource="{Binding}"
                            ScrollViewer.CanContentScroll="True"
                            ScrollViewer.HorizontalScrollBarVisibility="Visible"
                            ScrollViewer.VerticalScrollBarVisibility="Visible">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Level}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Level}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding IsSpec}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource HasSpec?}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Name="BtnDelLevel"
                                                Width="35"
                                                Height="20"
                                                Background="{x:Null}"
                                                Click="BtnDelLevel_Click">
                                                <Image
                                                    Width="35"
                                                    Height="15"
                                                    Source="/Images/DeleteIconsmall.png" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                </TabItem>
                <TabItem Header="{DynamicResource Year}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <StackPanel
                            Grid.Row="0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Label Content="{DynamicResource LevelLB}" FontSize="15" />
                            <ComboBox
                                Name="CBLevelYears"
                                Width="100"
                                Height="30"
                                Margin="0,0,10,0"
                                DisplayMemberPath="Level"
                                FontSize="15"
                                ItemsSource="{Binding}"
                                SelectedValuePath="ID"
                                SelectionChanged="ComboBox_Level_Year" />

                            <Label
                                VerticalAlignment="Center"
                                Content="{DynamicResource YearNameLB}"
                                FontSize="15" />
                            <TextBox
                                Name="YearTB"
                                Width="150"
                                Height="30"
                                VerticalAlignment="Center" />
                            <Button
                                Width="40"
                                Height="40"
                                Margin="5,0,5,0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="Button_Click_Year">
                                <Image Source="/Images/addsign.png" />
                            </Button>

                        </StackPanel>
                        <Button
                            Grid.ColumnSpan="2"
                            Width="50"
                            Height="50"
                            Margin="0,0,20,0"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="Button_Click_Import">
                            <Image Source="/Images/Import.png" />
                        </Button>
                        <DataGrid
                            Name="DGYear"
                            Grid.Row="1"
                            MinHeight="230"
                            MaxHeight="230"
                            Margin="0,10,0,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            ScrollViewer.CanContentScroll="True"
                            ScrollViewer.HorizontalScrollBarVisibility="Visible"
                            ScrollViewer.VerticalScrollBarVisibility="Visible">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Level}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Level}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Year}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Year}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Name="BtnDelYear"
                                                Width="35"
                                                Height="20"
                                                Background="{x:Null}"
                                                Click="BtnDelYear_Click">
                                                <Image
                                                    Width="35"
                                                    Height="15"
                                                    Source="/Images/DeleteIconsmall.png" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="{DynamicResource Speciality}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <StackPanel
                            Grid.Row="0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Label
                                VerticalAlignment="Center"
                                Content="{DynamicResource LevelLB}"
                                FontSize="15" />
                            <ComboBox
                                Name="CBLevelSpec"
                                Width="100"
                                Height="30"
                                Margin="0,0,10,0"
                                DisplayMemberPath="Level"
                                FontSize="15"
                                ItemsSource="{Binding}"
                                SelectedValuePath="ID"
                                SelectionChanged="CBLevelSpec_SelectionChanged" />
                            <Label
                                VerticalAlignment="Center"
                                Content="{DynamicResource YearLB}"
                                FontSize="15" />
                            <ComboBox
                                Name="CBYearSpec"
                                Width="100"
                                Height="30"
                                Margin="0,0,10,0"
                                DisplayMemberPath="Year"
                                FontSize="15"
                                ItemsSource="{Binding}"
                                SelectedValuePath="ID"
                                SelectionChanged="CBYearSpec_SelectionChanged" />
                            <Label
                                VerticalAlignment="Center"
                                Content="{DynamicResource SpecNameLB}"
                                FontSize="15" />
                            <TextBox
                                Name="SpecTB"
                                Width="100"
                                Height="30" />
                            <Button
                                Width="40"
                                Height="40"
                                Margin="5,0,5,0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="Button_Click_Spec">
                                <Image Source="/Images/addsign.png" />
                            </Button>


                        </StackPanel>
                        <Button
                            Grid.ColumnSpan="2"
                            Width="50"
                            Height="50"
                            Margin="0,0,20,0"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="Button_Click_Import">
                            <Image Source="/Images/Import.png" />
                        </Button>
                        <DataGrid
                            Name="DGSpec"
                            Grid.Row="1"
                            MinHeight="230"
                            MaxHeight="230"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            ScrollViewer.CanContentScroll="True"
                            ScrollViewer.HorizontalScrollBarVisibility="Visible"
                            ScrollViewer.VerticalScrollBarVisibility="Visible">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Level}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Level}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Year}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Year}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Speciality}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Speciality}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Name="BtnDelSpec"
                                                Width="35"
                                                Height="20"
                                                Background="{x:Null}"
                                                Click="BtnDelSpec_Click">
                                                <Image
                                                    Width="35"
                                                    Height="15"
                                                    Source="/Images/DeleteIconsmall.png" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                <TabItem Header="{DynamicResource Subject}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="55" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <StackPanel
                            Grid.Row="0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Label
                                VerticalAlignment="Center"
                                Content="{DynamicResource LevelLB}"
                                FontSize="15" />
                            <ComboBox
                                Name="CBLevelSub"
                                Width="100"
                                Height="30"
                                Margin="0,0,10,0"
                                DisplayMemberPath="Level"
                                FontSize="15"
                                ItemsSource="{Binding}"
                                SelectedValuePath="ID"
                                SelectionChanged="CBLevelSub_SelectionChanged" />
                            <Label
                                VerticalAlignment="Center"
                                Content="{DynamicResource YearLB}"
                                FontSize="15" />
                            <ComboBox
                                Name="CBYearSub"
                                Width="100"
                                Height="30"
                                Margin="0,0,10,0"
                                DisplayMemberPath="Year"
                                FontSize="15"
                                ItemsSource="{Binding}"
                                SelectedValuePath="ID"
                                SelectionChanged="CBYearSub_SelectionChanged" />
                            <StackPanel Name="SPSpec" Orientation="Horizontal">
                                <Label
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource SpecialityLB}"
                                    FontSize="15" />
                                <ComboBox
                                    Name="CBSpecSub"
                                    Width="100"
                                    Height="30"
                                    Margin="0,0,10,0"
                                    DisplayMemberPath="Speciality"
                                    FontSize="15"
                                    ItemsSource="{Binding}"
                                    SelectedValuePath="ID"
                                    SelectionChanged="CBSpecSub_SelectionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Label
                                    Width="110"
                                    VerticalAlignment="Center"
                                    Content="{DynamicResource SubjectNameLB}"
                                    FontSize="15" />
                                <StackPanel
                                    Name="SPSpec2"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Label Content="{DynamicResource SubjectExist}" FontSize="10" />
                                    <StackPanel
                                        Name="ExistSub"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"
                                        Visibility="Visible">
                                        <RadioButton
                                            Name="YesSub"
                                            VerticalAlignment="Center"
                                            Checked="YesSub_Checked"
                                            Content="{DynamicResource Yes}" />
                                        <RadioButton
                                            Name="NoSub"
                                            VerticalAlignment="Center"
                                            Checked="NoSub_Checked"
                                            Content="{DynamicResource No}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <TextBox
                                Name="SubTB"
                                Width="100"
                                Height="30" />
                            <ComboBox
                                Name="CBSubjectSub"
                                Width="100"
                                Height="25"
                                Margin="0,0,10,0"
                                DisplayMemberPath="Subject"
                                FontSize="15"
                                ItemsSource="{Binding}"
                                SelectedValuePath="ID"
                                SelectionChanged="CBSubjectSub_SelectionChanged"
                                Visibility="Collapsed" />
                            <Button
                                Width="40"
                                Height="40"
                                Margin="5,0,5,0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="Button_Click_Sub">
                                <Image Source="/Images/addsign.png" />
                            </Button>

                        </StackPanel>
                        <Button
                            Grid.ColumnSpan="2"
                            Width="50"
                            Height="50"
                            Margin="0,0,20,0"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="Button_Click_Import">
                            <Image Source="/Images/Import.png" />
                        </Button>
                        <DataGrid
                            Name="DGSubjects"
                            Grid.Row="1"
                            MinHeight="230"
                            MaxHeight="230"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            ScrollViewer.CanContentScroll="True"
                            ScrollViewer.HorizontalScrollBarVisibility="Visible"
                            ScrollViewer.VerticalScrollBarVisibility="Visible">

                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Level}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Level}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Year}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Year}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn x:Name="DGTCSpec" Binding="{Binding Speciality}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Speciality}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Subject}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock Text="{DynamicResource Subject}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Name="BtnDelSubject"
                                                Width="35"
                                                Height="20"
                                                Background="{x:Null}"
                                                Click="BtnDelSubject_Click">
                                                <Image
                                                    Width="35"
                                                    Height="15"
                                                    Source="/Images/DeleteIconsmall.png" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                    </Grid>
                </TabItem>
                <TabItem Header="{DynamicResource Rooms}">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Label
                                VerticalAlignment="Center"
                                Content="{DynamicResource RoomNameLB}"
                                FontSize="15" />
                            <TextBox
                                Name="RoomTB"
                                Width="100"
                                Height="30" />
                            <Label
                                VerticalAlignment="Center"
                                Content="{DynamicResource MaxSeatsLB}"
                                FontSize="15" />
                            <TextBox
                                Name="RoomSeatsTB"
                                Width="100"
                                Height="30" />

                            <Button
                                Width="40"
                                Height="40"
                                Margin="5,0,5,0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Click="Button_Click_Room">
                                <Image Source="/Images/addsign.png" />
                            </Button>

                        </StackPanel>
                        <Button
                            Grid.ColumnSpan="2"
                            Width="50"
                            Height="50"
                            Margin="0,0,20,0"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="Button_Click_Import">
                            <Image Source="/Images/Import.png" />
                        </Button>
                        <DataGrid
                            Name="DGRoom"
                            Grid.Row="1"
                            MinHeight="230"
                            MaxHeight="230"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            AutoGenerateColumns="False"
                            CanUserAddRows="False"
                            CellEditEnding="DGRoom_CellEditEnding"
                            ScrollViewer.CanContentScroll="True"
                            ScrollViewer.HorizontalScrollBarVisibility="Visible"
                            ScrollViewer.VerticalScrollBarVisibility="Visible">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="100" Binding="{Binding Room}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock x:Name="Room" Text="{DynamicResource Room}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Width="100" Binding="{Binding Seats}">
                                    <DataGridTextColumn.Header>
                                        <TextBlock x:Name="Seats" Text="{DynamicResource MaxSeats}" />
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Name="BtnDelRoom"
                                                Width="35"
                                                Height="20"
                                                Background="{x:Null}"
                                                Click="BtnDelRoom_Click">
                                                <Image
                                                    Width="35"
                                                    Height="15"
                                                    Source="/Images/DeleteIconsmall.png" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Grid>
</UserControl>
