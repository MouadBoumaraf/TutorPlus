<Window
    x:Class="Gestion_De_Cours.Panels.Login"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Gestion_De_Cours.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Login"
    Width="1800"
    Height="1200"
    KeyDown="Window_KeyDown"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="Images/background1.jpg" />
        </Grid.Background>
        <Border
            Width="350"
            Padding="30"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#E0E0E0"
            CornerRadius="20">



            <!--  Main container  -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <!--  Header  -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Left logo  -->
                    <Image
                        Grid.Column="0"
                        Height="60"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Source="favicon (2).ico" />

                    <!--  Version text  -->
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="DarkGreen"
                            Text="Version" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="25"
                            Foreground="DarkGreen"
                            Text="2.0.0.3" />
                    </StackPanel>

                    <!--  Right logo  -->
                    <Image
                        Grid.Column="2"
                        Height="60"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Source="favicon (2).ico" />
                </Grid>

                <!--  Username  -->
                <StackPanel Margin="0,10" Orientation="Horizontal">
                    <Label
                        Width="80"
                        Content="Username :"
                        FontSize="14" />
                    <TextBox
                        Name="UserName"
                        Width="150"
                        Height="25"
                        Background="White"
                        FontSize="15" />
                </StackPanel>

                <!--  Password  -->
                <StackPanel Margin="0,10" Orientation="Horizontal">
                    <Label
                        Width="80"
                        Content="Password :"
                        FontSize="14" />
                    <PasswordBox
                        Name="Password"
                        Width="150"
                        Height="25"
                        Background="White"
                        FontSize="15" />
                    <TextBox
                        Name="PasswordUnmask"
                        Width="150"
                        Height="25"
                        FontSize="14"
                        Visibility="Collapsed" />
                </StackPanel>

                <!--  Database  -->
                <StackPanel Margin="0,10" Orientation="Horizontal">
                    <Label
                        Width="80"
                        Content="Database :"
                        FontSize="14" />
                    <ComboBox
                        Name="ComboDB"
                        Width="150"
                        Height="25"
                        DisplayMemberPath="name"
                        FontSize="14"
                        ItemsSource="{Binding}"
                        SelectionChanged="ComboBox_SelectionChanged" />
                </StackPanel>

                <!--  Login button  -->
                <Button
                    Width="120"
                    Height="30"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"
                    Background="#EBF5EB"
                    Click="Button_Click"
                    Content="Login"
                    FontSize="16"
                    Foreground="Black" />
            </StackPanel>
        </Border>

    </Grid>
</Window>
