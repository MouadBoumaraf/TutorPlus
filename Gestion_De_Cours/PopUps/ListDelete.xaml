<Window
    x:Class="Gestion_De_Cours.PopUps.ListDelete"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Gestion_De_Cours.PopUps"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ListDelete"
    Width="400"
    Height="450"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
            <Label
                Margin="10"
                VerticalAlignment="Center"
                Content="Search :"
                FontSize="15" />
            <TextBox
                Name="TBSearch"
                Width="200"
                Height="35"
                TextChanged="TextBox_TextChanged" />
            <Button
                Width="50"
                Height="20"
                Margin="10,0,0,0"
                Click="Button_Click"
                Content="+" />
        </StackPanel>

        <DataGrid
            Name="DG"
            Grid.Row="1"
            Margin="10"
            AutoGenerateColumns="False"
            FontSize="15"
            IsReadOnly="True"
            ItemsSource="{Binding}" />
    </Grid>
</Window>
