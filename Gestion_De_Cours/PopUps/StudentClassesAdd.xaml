<Window
    x:Class="Gestion_De_Cours.PopUps.StudentClassesAdd"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Gestion_De_Cours.PopUps"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="StudentClassesAdd"
    Width="300"
    Height="250"
    mc:Ignorable="d">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock
                Name="LabelStudent"
                Width="280"
                Margin="0,10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="20"
                TextWrapping="Wrap">
                this is a test
            </TextBlock>
            <ComboBox
                Name="CustomComboBox"
                Width="200"
                Height="30"
                Visibility="Visible">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox
                                Name="checkBox"
                                Checked="checkBox_Checked"
                                IsChecked="{Binding Checked}"
                                Unchecked="checkBox_Unchecked" />
                            <TextBlock
                                Name="ItemTextBlock"
                                Margin="5,0,0,0"
                                Text="{Binding Name}" />

                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock
                Name="LabelClasses"
                Margin="10"
                HorizontalAlignment="Center"
                FontSize="20">
                this is a test
            </TextBlock>
            <Button
                Width="100"
                Height="30"
                Margin="10"
                Click="Button_Click"
                Content="+" />
        </StackPanel>

    </Grid>
</Window>
