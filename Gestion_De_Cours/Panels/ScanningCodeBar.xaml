<Window
    x:Class="Gestion_De_Cours.Panels.ScanningCodeBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:local="clr-namespace:Gestion_De_Cours.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ScanningCodeBar"
    Width="500"
    Height="500"
    dx:ThemeManager.ThemeName="None"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <FontFamily x:Key="FontLabel">pack://application:,,,/Fonts/#Droid Arabic Kufi</FontFamily>
                </ResourceDictionary>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition />
            <RowDefinition Height="90" />
        </Grid.RowDefinitions>
        <StackPanel
            Grid.Row="0"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Label
                VerticalAlignment="Center"
                Content="{DynamicResource BarCodeLB}"
                FontSize="20" />
            <TextBox
                Name="CodebarTxt"
                Width="200"
                Height="40"
                FontSize="15"
                TextChanged="TextBox_TextChanged" />
        </StackPanel>

        <GroupBox
            Grid.Row="1"
            Width="400"
            BorderBrush="Black"
            BorderThickness="2">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <Image
                        Name="IMGTeacher"
                        Width="30"
                        Height="30"
                        Source="/Images/Student.png" />

                    <Label Content="{DynamicResource StudentInfo}" />
                </StackPanel>
            </GroupBox.Header>
            <StackPanel Orientation="Vertical">
                <Button
                    Width="70"
                    Height="30"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="Button_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Name="IMGSave" Source="/Images/eye.png" />
                        <TextBlock
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Text="{DynamicResource View}" />
                    </StackPanel>
                </Button>
                <StackPanel Orientation="Horizontal">
                    <StackPanel
                        Width="230"
                        HorizontalAlignment="Left"
                        Orientation="Vertical">
                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                            <Label
                                Width="95"
                                Content="{DynamicResource FirstNameLB}"
                                FontSize="15" />
                            <Border
                                Width="120"
                                Height="28"
                                BorderBrush="Black"
                                BorderThickness="1">
                                <TextBlock
                                    Name="FName"
                                    Height="28"
                                    FontSize="15" />
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                            <Label
                                Width="95"
                                Content="{DynamicResource LastNameLB}"
                                FontSize="15" />
                            <Border
                                Width="120"
                                Height="28"
                                BorderBrush="Black"
                                BorderThickness="1">
                                <TextBlock
                                    Name="LName"
                                    Height="28"
                                    FontSize="15" />
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                            <Label
                                Width="95"
                                Content="{DynamicResource LevelLB}"
                                FontSize="15" />
                            <Border
                                Width="120"
                                Height="28"
                                BorderBrush="Black"
                                BorderThickness="1">
                                <TextBlock
                                    Name="Level"
                                    Height="28"
                                    FontSize="15" />
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                            <Label
                                Width="95"
                                Content="{DynamicResource YearLB}"
                                FontSize="15" />
                            <Border
                                Width="120"
                                Height="28"
                                BorderBrush="Black"
                                BorderThickness="1">
                                <TextBlock
                                    Name="Year"
                                    Height="28"
                                    FontSize="15" />
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                            <Label
                                Width="95"
                                Content="{DynamicResource SpecialityLB}"
                                FontSize="15" />
                            <Border
                                Width="120"
                                Height="28"
                                BorderBrush="Black"
                                BorderThickness="1">
                                <TextBlock Name="Speciality" Height="28" />
                            </Border>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                            <Label
                                Width="95"
                                Content="{DynamicResource BirthDateLB}"
                                FontSize="15" />
                            <Border
                                Width="120"
                                Height="28"
                                BorderBrush="Black"
                                BorderThickness="1">
                                <TextBlock Name="BirthDate" Height="28" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    <Border
                        Width="100"
                        Height="100"
                        Margin="30,0,0,0"
                        VerticalAlignment="Top"
                        BorderBrush="Black"
                        BorderThickness="2">
                        <Image
                            Name="Pic"
                            Width="100"
                            Height="100"
                            VerticalAlignment="Center"
                            Stretch="UniformToFill" />
                    </Border>
                </StackPanel>
            </StackPanel>
        </GroupBox>
        <StackPanel
            Name="SPPresent"
            Grid.Row="2"
            Width="395"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Visibility="Collapsed">
            <Label
                Name="LBPresent"
                Content=""
                FontSize="15" />
            <Button
                Width="50"
                Height="25"
                Background="#a6be85"
                Click="Present_Click"
                Content="{DynamicResource Present}" />
        </StackPanel>
    </Grid>
</Window>
