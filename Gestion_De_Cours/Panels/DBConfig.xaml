<Window
    x:Class="Gestion_De_Cours.Panels.DBConfig"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:local="clr-namespace:Gestion_De_Cours.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DBConfig"
    Width="400"
    Height="450"
    dx:ThemeManager.ThemeName="None"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Label
                Width="170"
                VerticalAlignment="Center"
                Content="DataBaseName :"
                FontSize="20" />
            <TextBox
                Name="DBName"
                Width="200"
                Height="40"
                FontSize="15" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Label
                Width="170"
                VerticalAlignment="Center"
                Content="Server Name :"
                FontSize="20" />
            <TextBox
                Name="ServerName"
                Width="200"
                Height="40"
                FontSize="15" />
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Label
                Width="170"
                VerticalAlignment="Center"
                Content="UserName :"
                FontSize="20" />
            <TextBox
                Name="UserName"
                Width="200"
                Height="40"
                FontSize="15" />
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Label
                Width="170"
                VerticalAlignment="Center"
                Content="Password :"
                FontSize="20" />
            <TextBox
                Name="PasswordName"
                Width="200"
                Height="40"
                FontSize="15" />
        </StackPanel>
        <Button
            Grid.Row="4"
            Width="100"
            Height="40"
            Click="Button_Click"
            Content="Submit" />
    </Grid>
</Window>
