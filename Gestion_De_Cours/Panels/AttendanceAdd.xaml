<Window
    x:Class="Gestion_De_Cours.Panels.AttendanceAdd"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Convert="clr-namespace:Gestion_De_Cours.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:local="clr-namespace:Gestion_De_Cours.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rs="clr-namespace:Gestion_De_Cours.Properties"
    Title=""
    Width="800"
    Height="700"
    dx:ThemeManager.ThemeName="None"
    KeyDown="Window_KeyDown"
    PreviewKeyDown="Window_PreviewKeyDown"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Convert:ForegroundConverterPayment x:Key="ForegroundConverterPayment" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Name="RowAddStudent" Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <!-- <Button Margin="10"   Height="30" Width="100" Content="{DynamicResource Print}" Click="Button_Click_1"></Button> -->
        <Button
            Name="btnDelete"
            Grid.Row="2"
            Grid.Column="0"
            Width="100"
            Height="30"
            HorizontalAlignment="Center"
            Background="#EF5350"
            Foreground="White"
            FontWeight="Bold"
            FontSize="15"
            BorderThickness="0"
            Padding="0"
            Click="Button_Click_Absent"
            Content="{DynamicResource Absent}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button
            Name="btnPresent"
            Grid.Row="2"
            Grid.Column="1"
            Width="100"
            Height="30"
            HorizontalAlignment="Center"
            Background="#66BB6A"
            Foreground="White"
            FontWeight="Bold"
            FontSize="15"
            BorderThickness="0"
            Padding="0"
            Click="Button_Click_Present"
            Content="{DynamicResource Present}">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <StackPanel
            Grid.ColumnSpan="2"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Label
                VerticalAlignment="Center"
                Content="{DynamicResource BarCodeLB}"
                FontSize="20" />
            <TextBox
                Name="CodebarTxt"
                Width="200"
                Height="40"
                Margin="5,10,5,10"
                FontSize="15"
                PreviewKeyDown="CodebarTxt_PreviewKeyDown"
                TextChanged="TextBox_TextChanged" />
            <Button
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Width="80"
                Height="80"
                Margin="20,0,0,0"
                HorizontalAlignment="Right"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click_ChangeStudents"
                Visibility="Visible">
                <StackPanel>
                    <Image
                        Width="60"
                        Height="60"
                        Source="/Images/Change256.png" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="9"
                        FontWeight="Bold"
                        Text="{DynamicResource ChangeGroup}" />
                </StackPanel>
            </Button>

            <Button
                Name="BtnExtraStudents"
                Width="80"
                Height="80"
                Margin="10,0,0,0"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="BtnExtraStudents_Click"
                Visibility="Visible">
                <StackPanel HorizontalAlignment="Center">
                    <!--  Image  -->
                    <Image
                        Width="60"
                        Height="60"
                        Source="/Images/AddSign.png" />
                    <!--  Text  -->
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="9"
                        FontWeight="Bold"
                        Text="{DynamicResource ExtraStudents}" />
                </StackPanel>
            </Button>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            
        </StackPanel>
        <ListView
            Name="ListClass"
            Grid.Row="3"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            FontSize="14"
            ItemsSource="{Binding}"
            MouseDoubleClick="ListStudents_MouseDoubleClick"
            SelectionChanged="ListStudents_SelectionChanged"
            SelectionMode="Extended">

            <!--  Context Menu  -->
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        Name="ChangePrice"
                        Click="ChangePrice_Click"
                        Header="{DynamicResource ChangePrice}" />
                </ContextMenu>
            </ListView.ContextMenu>

            <!--  GridView for columns  -->
            <ListView.View>
                <GridView>
                    <!--  Student Name  -->
                    <GridViewColumn Width="150" Header="{DynamicResource SName}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Gender}" Value="1">
                                                    <Setter Property="Foreground" Value="Salmon" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Gender}" Value="0">
                                                    <Setter Property="Foreground" Value="Blue" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  Payments  -->
                    <GridViewColumn Width="100" Header="{DynamicResource Payments}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Foreground="{Binding Sessions, Converter={StaticResource ForegroundConverterPayment}}"
                                    Text="{Binding Sessions}"
                                    TextAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  Presence  -->
                    <GridViewColumn Width="75" Header="{DynamicResource Presense}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="4"
                                    Padding="6,2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    CornerRadius="12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="TextElement.Foreground" Value="White" />
                                            <Style.Triggers>
                                                <!--  Absent  -->
                                                <DataTrigger Binding="{Binding Status}" Value="0">
                                                    <Setter Property="Background" Value="#EF5350" />
                                                    <Setter Property="TextElement.Foreground" Value="White" />
                                                </DataTrigger>
                                                <!--  Present  -->
                                                <DataTrigger Binding="{Binding Status}" Value="1">
                                                    <Setter Property="Background" Value="#4CAF50" />
                                                    <Setter Property="TextElement.Foreground" Value="White" />
                                                </DataTrigger>
                                                <!--  Justified  -->
                                                <DataTrigger Binding="{Binding Status}" Value="2">
                                                    <Setter Property="Background" Value="#FF9800" />
                                                    <Setter Property="TextElement.Foreground" Value="White" />
                                                </DataTrigger>
                                                <!--  Late  -->
                                                <DataTrigger Binding="{Binding Status}" Value="3">
                                                    <Setter Property="Background" Value="#FFD600" />
                                                    <Setter Property="TextElement.Foreground" Value="Black" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Text="{Binding StatusText}"
                                        TextAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>


                    <!--  Reason  -->
                    <GridViewColumn
                        Width="130"
                        DisplayMemberBinding="{Binding Reason}"
                        Header="{DynamicResource ReasonofAbsent}" />


                </GridView>
            </ListView.View>
        </ListView>


        <DataGrid
            Name="ListFormation"
            Grid.Row="3"
            Grid.RowSpan="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AutoGenerateColumns="False"
            GridLinesVisibility="All"
            IsReadOnly="True"
            ItemsSource="{Binding}"
            MouseDoubleClick="ListStudents_MouseDoubleClick"
            SelectionChanged="ListStudents_SelectionChanged"
            SelectionMode="Extended"
            SelectionUnit="FullRow"
            Visibility="Collapsed">
            <DataGrid.Columns>
                <DataGridTextColumn Width="auto" Binding="{Binding Name}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource SName}" />
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Gender}" Value="1">
                                    <Setter Property="TextBlock.Foreground" Value="Salmon" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Gender}" Value="0">
                                    <Setter Property="TextBlock.Foreground" Value="Blue" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Width="auto" Binding="{Binding Sessions}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource PaidSessions}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="auto" Binding="{Binding HoursRemain}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource RemainingHours}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="auto">
                    <DataGridTemplateColumn.Header>
                        <TextBlock HorizontalAlignment="Center" Text="{DynamicResource Presense}" />
                    </DataGridTemplateColumn.Header>

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!--  Disable default selection highlight  -->
                            <Border
                                Margin="4"
                                Padding="6,2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                CornerRadius="12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Gray" />
                                        <Setter Property="TextElement.Foreground" Value="White" />
                                        <Style.Triggers>
                                            <!--  Absent  -->
                                            <DataTrigger Binding="{Binding Status}" Value="0">
                                                <Setter Property="Background" Value="#EF5350" />
                                            </DataTrigger>
                                            <!--  Present  -->
                                            <DataTrigger Binding="{Binding Status}" Value="1">
                                                <Setter Property="Background" Value="#4CAF50" />
                                            </DataTrigger>
                                            <!--  Justified  -->
                                            <DataTrigger Binding="{Binding Status}" Value="2">
                                                <Setter Property="Background" Value="#FF9800" />
                                            </DataTrigger>
                                            <!--  Late  -->
                                            <DataTrigger Binding="{Binding Status}" Value="3">
                                                <Setter Property="Background" Value="#FFD600" />
                                                <Setter Property="TextElement.Foreground" Value="Black" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Text="{Binding StatusText}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                    <!--  IMPORTANT: Disable default DataGrid cell background  -->
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                </DataGridTemplateColumn>


                <DataGridTemplateColumn Width="auto" Header="{DynamicResource Payment}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button
                                    Name="BtnPayment_formation"
                                    Width="40"
                                    Click="BtnPayment_Click">
                                    <Image
                                        Width="50"
                                        Height="20"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Source="/Images/Payment.png" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
        <StackPanel
            Grid.Row="4"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Left"
            Orientation="Horizontal">
            <Label
                Name="TETLabel"
                Grid.Row="4"
                VerticalAlignment="Center"
                Content="{DynamicResource TEntranceTime}"
                FontSize="15" />
            <TextBox
                Name="TET"
                Width="100"
                Height="30" />
            <StackPanel
                Name="SPTime"
                Orientation="Horizontal"
                Visibility="Collapsed">
                <Label
                    VerticalContentAlignment="Center"
                    Content="{DynamicResource DurationSessionLB}"
                    FontSize="15" />
                <ComboBox
                    Name="CBHour"
                    Width="60"
                    Height="30"
                    VerticalContentAlignment="Center"
                    FontSize="20">
                    <ComboBoxItem>0</ComboBoxItem>
                    <ComboBoxItem>1</ComboBoxItem>
                    <ComboBoxItem>2</ComboBoxItem>
                    <ComboBoxItem>3</ComboBoxItem>
                    <ComboBoxItem>4</ComboBoxItem>
                    <ComboBoxItem>5</ComboBoxItem>
                </ComboBox>
                <Label
                    VerticalContentAlignment="Center"
                    Content=":"
                    FontSize="25" />
                <ComboBox
                    Name="CBMinute"
                    Width="60"
                    Height="30"
                    VerticalContentAlignment="Center"
                    FontSize="20">
                    <ComboBoxItem>00</ComboBoxItem>
                    <ComboBoxItem>15</ComboBoxItem>
                    <ComboBoxItem>30</ComboBoxItem>
                    <ComboBoxItem>45</ComboBoxItem>
                </ComboBox>

            </StackPanel>
            <Label
                VerticalAlignment="Center"
                Content="{DynamicResource DateLB}"
                FontSize="16" />
            <DatePicker
                Name="Date"
                Width="200"
                Height="30"
                VerticalAlignment="Center"
                FontSize="15"
                Language="fr-FR"
                SelectedDateChanged="Date_SelectedDateChanged" />

            <Label
                Name="NoteLB"
                Grid.Row="4"
                VerticalAlignment="Center"
                Content="{DynamicResource NoteLB}"
                FontSize="15" />
            <TextBox
                Name="Note"
                Width="180"
                Height="30" />

        </StackPanel>
        <StackPanel
            Grid.Row="4"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Center"
            Orientation="Horizontal" />
        <StackPanel
            Grid.Row="5"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Label
                Width="60"
                VerticalContentAlignment="Center"
                Content="{DynamicResource RoomLB}"
                FontSize="15" />
            <ComboBox
                Name="CRoom"
                Width="100"
                Height="30"
                Margin="0,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                DisplayMemberPath="Room"
                FontSize="15"
                SelectedValuePath="ID"
                SelectionChanged="CRoom_SelectionChanged" />
            <Label
                VerticalContentAlignment="Center"
                Content="{DynamicResource FromLB}"
                FontSize="15" />
            <ComboBox
                Name="HFrom"
                Width="80"
                Height="35"
                Margin="0,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="20"
                SelectedValuePath="Hour"
                SelectionChanged="HFrom_SelectionChanged"
                Text="HH">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel VerticalAlignment="Top" Orientation="Horizontal">
                            <Label
                                VerticalAlignment="Top"
                                Content="{Binding Hour}"
                                FontSize="15">
                                <Label.Resources>
                                    <Style TargetType="{x:Type Label}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="0">
                                                <Setter Property="Foreground" Value="YellowGreen" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="1">
                                                <Setter Property="Foreground" Value="Yellow" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="2">
                                                <Setter Property="Foreground" Value="Red" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Label.Resources>
                            </Label>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Label
                VerticalContentAlignment="Center"
                Content=" : "
                FontSize="15" />
            <ComboBox
                Name="MFrom"
                Width="80"
                Height="35"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="15"
                SelectedValuePath="Hour"
                SelectionChanged="MFrom_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel VerticalAlignment="Top" Orientation="Horizontal">
                            <Label
                                VerticalAlignment="Top"
                                Content="{Binding Hour}"
                                FontSize="15">
                                <Label.Resources>
                                    <Style TargetType="{x:Type Label}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="0">
                                                <Setter Property="Foreground" Value="YellowGreen" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="1">
                                                <Setter Property="Foreground" Value="Yellow" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="2">
                                                <Setter Property="Foreground" Value="Red" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Label.Resources>
                            </Label>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Label
                VerticalContentAlignment="Center"
                Content="{DynamicResource ToLB}"
                FontSize="15" />
            <ComboBox
                Name="HTo"
                Width="80"
                Height="35"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="15"
                SelectedValuePath="Hour"
                SelectionChanged="HTo_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel VerticalAlignment="Top" Orientation="Horizontal">
                            <Label
                                VerticalAlignment="Top"
                                Content="{Binding Hour}"
                                FontSize="15">
                                <Label.Resources>
                                    <Style TargetType="{x:Type Label}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="0">
                                                <Setter Property="Foreground" Value="YellowGreen" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="1">
                                                <Setter Property="Foreground" Value="Yellow" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="2">
                                                <Setter Property="Foreground" Value="Red" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Label.Resources>
                            </Label>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Label
                VerticalContentAlignment="Center"
                Content=" : "
                FontSize="15" />
            <ComboBox
                Name="MTo"
                Width="80"
                Height="35"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="15"
                SelectedValuePath="Hour"
                SelectionChanged="MTo_SelectionChanged">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel VerticalAlignment="Top" Orientation="Horizontal">
                            <Label
                                VerticalAlignment="Top"
                                Content="{Binding Hour}"
                                FontSize="15">
                                <Label.Resources>
                                    <Style TargetType="{x:Type Label}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="0">
                                                <Setter Property="Foreground" Value="YellowGreen" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="1">
                                                <Setter Property="Foreground" Value="Yellow" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="2">
                                                <Setter Property="Foreground" Value="Red" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Label.Resources>
                            </Label>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
        <Button
            Grid.Row="6"
            Grid.Column="0"
            Width="100"
            Height="30"
            Click="Button_Click_4"
            Content="{DynamicResource Cancel}" />
        <Button
            Grid.Row="6"
            Grid.Column="1"
            Width="100"
            Height="30"
            Click="Button_Click"
            Content="{DynamicResource Insert}" />
        <Popup
            Name="MyPopup"
            Grid.ColumnSpan="2"
            IsOpen="False"
            Opened="MyPopup_Opened"
            Placement="Center">
            <!--  Content of the Popup  -->
            <Border
                Grid.Column="0"
                Width="200"
                Height="150"
                Background="White">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        Name="PopupText"
                        FontSize="18"
                        Text="This is a popup!" />
                    <!--  Add other content to your popup here  -->
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
