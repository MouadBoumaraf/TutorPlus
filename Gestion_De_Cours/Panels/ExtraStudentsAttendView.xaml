<Window
    x:Class="Gestion_De_Cours.Panels.ExtraStudentsAttendView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:local="clr-namespace:Gestion_De_Cours.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ExtraStudentsAttendView"
    Width="320"
    Height="360"
    dx:ThemeManager.ThemeName="None"
    WindowStartupLocation="CenterScreen"
    WindowState="Normal"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>

    </Window.Resources>
    <Grid>
        <StackPanel>
            <Label
                Name="LBName"
                HorizontalAlignment="Center"
                FontSize="20">
                this is a test
            </Label>
            <GroupBox
                Grid.Row="2"
                Grid.RowSpan="1"
                Grid.ColumnSpan="2"
                BorderBrush="Black"
                BorderThickness="1">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <Image
                            Name="IMGTeacher"
                            Width="30"
                            Height="30"
                            Source="/Images/AddSign.png" />

                        <Label
                            Margin="5,0,0,0"
                            Content="{DynamicResource Add}"
                            FontSize="15" />
                    </StackPanel>
                </GroupBox.Header>
                <Grid>
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Label
                            Margin="0,0,5,0"
                            Content="{DynamicResource NameLB}"
                            FontSize="15" />
                        <TextBox
                            Name="TBName"
                            Width="150"
                            Height="25"
                            FontSize="14" />
                        <Button
                            Width="40"
                            Height="20"
                            Margin="5,0,0,0"
                            Click="Button_Click"
                            Content="+" />
                    </StackPanel>
                </Grid>
            </GroupBox>
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                <Button
                    Name="BtnPrint"
                    Width="60"
                    Height="60"
                    Margin="0,0,10,0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="BtnPrint_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <!--  Image  -->
                        <Image
                            Width="32"
                            Height="32"
                            Source="/Images/print.png" />
                        <!--  Text  -->
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="8"
                            FontWeight="Bold"
                            Text="{DynamicResource Print}" />
                    </StackPanel>
                </Button>
                <Button
                    Name="BtnDelete"
                    Width="60"
                    Height="60"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="BtnDelete_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <!--  Image  -->
                        <Image
                            Width="32"
                            Height="32"
                            Source="/Images/DeleteIcon.png" />
                        <!--  Text  -->
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="8"
                            FontWeight="Bold"
                            Text="{DynamicResource Delete}" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <DataGrid
                Name="DGExtra"
                Height="150"
                Margin="5"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                FontSize="15"
                ItemsSource="{Binding}"
                SelectionMode="Single"
                Visibility="Visible">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="200" Binding="{Binding Name}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Name}" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="100" Binding="{Binding Price}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{DynamicResource Price}" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Window>
