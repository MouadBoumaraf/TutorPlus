<Window
    x:Class="Gestion_De_Cours.Panels.Justif"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Convert="clr-namespace:Gestion_De_Cours.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:local="clr-namespace:Gestion_De_Cours.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Justif"
    Width="625"
    Height="450"
    dx:ThemeManager.ThemeName="None"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <FontFamily x:Key="FontLabel">pack://application:,,,/Fonts/#Droid Arabic Kufi</FontFamily>
                </ResourceDictionary>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <StackPanel Grid.RowSpan="2" Orientation="Horizontal">
            <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                <StackPanel
                    Grid.Row="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">

                    <Label
                        Width="60"
                        VerticalAlignment="Center"
                        Content="{DynamicResource ClassLB}"
                        FontSize="15" />
                    <dxe:ComboBoxEdit
                        Name="CBclass"
                        Width="200"
                        Height="35"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        dx:ThemeManager.ThemeName="Office2019Colorful"
                        AutoComplete="True"
                        DisplayMember="CName"
                        EditValueChanged="CBclass_EditValueChanged"
                        FontSize="15"
                        ImmediatePopup="True"
                        IncrementalFiltering="True"
                        IsTextEditable="True"
                        ValueMember="ID" />

                    <Label
                        Width="70"
                        VerticalAlignment="Center"
                        Content="{DynamicResource StudentLB}"
                        FontSize="15" />

                    <dxe:ComboBoxEdit
                        Name="CBStudent"
                        Width="200"
                        Height="35"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        dx:ThemeManager.ThemeName="Office2019Colorful"
                        AutoComplete="True"
                        DisplayMember="Name"
                        EditValueChanged="CBStudent_EditValueChanged"
                        FontSize="15"
                        ImmediatePopup="True"
                        IncrementalFiltering="True"
                        IsTextEditable="True"
                        ValueMember="ID">

                        <dxe:ComboBoxEdit.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image
                                        Width="50"
                                        Height="35"
                                        Source="{Binding Picture}" />
                                    <Label Content="{Binding Name}" FontSize="15">
                                        <Label.Resources>
                                            <Style TargetType="{x:Type Label}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Gender}" Value="0">
                                                        <Setter Property="Foreground" Value="Blue" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Gender}" Value="1">
                                                        <Setter Property="Foreground" Value="Pink" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Label.Resources>
                                    </Label>
                                </StackPanel>
                            </DataTemplate>
                        </dxe:ComboBoxEdit.ItemTemplate>
                    </dxe:ComboBoxEdit>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Label
                        Width="60"
                        VerticalAlignment="Center"
                        Content="{DynamicResource DateLB}"
                        FontSize="15" />
                    <DatePicker
                        Name="Date"
                        Width="200"
                        Height="35"
                        FontSize="15" />
                    <Label
                        Width="70"
                        Margin="0,0,0,0"
                        VerticalAlignment="Center"
                        Content="{DynamicResource ReasonLB}"
                        FontSize="15" />
                    <TextBox
                        Name="TBReason"
                        Width="200"
                        Height="35"
                        Margin="0,6,0,4"
                        VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <Button
                Name="BtnExtraSes"
                Width="70"
                Height="70"
                Margin="10,0,0,0"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="Button_Click">
                <Image
                    Width="50"
                    Height="50"
                    Source="/Images/AddSign.png" />
            </Button>
        </StackPanel>
        <DataGrid
            Name="DGJustif"
            Grid.Row="2"
            Margin="10"
            AutoGenerateColumns="False"
            FontSize="15"
            IsReadOnly="True"
            ItemsSource="{Binding}">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem
                        Name="Delete"
                        Click="BtnDelJustif_Click"
                        Header="{DynamicResource Delete}">
                        <MenuItem.Icon>
                            <Image
                                Width="16"
                                Height="16"
                                Source="/Images/DeleteIconsmall.png" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Sname}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource SName}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding CName}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource ClassName}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Date}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource Date}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Reason}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource ReasonofAbsent}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
