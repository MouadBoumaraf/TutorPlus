<Window
    x:Class="Gestion_De_Cours.Panels.TeacherPaymentGroup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:local="clr-namespace:Gestion_De_Cours.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TeacherPaymentGroup"
    Width="800"
    Height="450"
    dx:ThemeManager.ThemeName="None"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <DataGrid
            Name="AttendanceDG"
            Grid.Row="0"
            Grid.RowSpan="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AutoGenerateColumns="False"
            FontSize="15"
            GridLinesVisibility="All"
            IsReadOnly="True"
            ItemsSource="{Binding}"
            SelectedCellsChanged="AttendanceDG_SelectedCellsChanged"
            SelectionMode="Single"
            SelectionUnit="Cell">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="150"
                    Binding="{Binding Name}"
                    Header="Student Name">
                    <DataGridTextColumn.CellStyle>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Gender}" Value="1">
                                    <Setter Property="TextBlock.Foreground" Value="Salmon" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Gender}" Value="0">
                                    <Setter Property="TextBlock.Foreground" Value="Blue" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.CellStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding ID}" Visibility="Collapsed" />
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel
            Grid.Row="1"
            Grid.ColumnSpan="2"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Label Content="Total Price : " FontSize="20" />
            <Border BorderBrush="Black" BorderThickness="1">
                <TextBlock
                    Name="Total"
                    Width="100"
                    Height="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="20" />
            </Border>
            <Label
                Margin="10,0,0,0"
                VerticalContentAlignment="Center"
                Content="Date :"
                FontSize="20" />
            <DatePicker
                Name="Date"
                Width="180"
                Height="30"
                VerticalAlignment="Center"
                FontSize="15"
                Language="fr-FR" />
            <Label Content="Note :" FontSize="20" />
            <TextBox
                Name="Note"
                Width="200"
                Height="30"
                FontSize="15" />
        </StackPanel>
        <Button
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="1"
            Width="100"
            Height="25"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Content="Cancel" />
        <Button
            Grid.Row="2"
            Grid.Column="1"
            Grid.ColumnSpan="1"
            Width="100"
            Height="25"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="Button_Click"
            Content="Submit" />

    </Grid>
</Window>
