<Window
    x:Class="Gestion_De_Cours.Panels.TeacherAdd"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:local="clr-namespace:Gestion_De_Cours.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:rs="clr-namespace:Gestion_De_Cours.Properties"
    Title="{DynamicResource TeacherAdd}"
    Width="600"
    Height="480"
    dx:ThemeManager.ThemeName="None"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <TabControl TabStripPlacement="Top">
        <TabItem>
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Images/teacher.png" />
                    <Label Content="{DynamicResource TeacherInfo}" FontSize="12" />
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />

                </Grid.RowDefinitions>
                <StackPanel
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal">
                    <Label
                        Width="120"
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource FirstNameLB}"
                        FontSize="15" />
                    <TextBox
                        Name="FName"
                        Grid.ColumnSpan="2"
                        Width="300"
                        Height="30"
                        HorizontalAlignment="Left"
                        FontSize="17"
                        PreviewKeyDown="FName_KeyDown" />
                </StackPanel>
                <StackPanel
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal">
                    <Label
                        Grid.Row="1"
                        Grid.Column="0"
                        Width="120"
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource LastNameLB}"
                        FontSize="15" />
                    <TextBox
                        Name="LName"
                        Grid.ColumnSpan="2"
                        Width="300"
                        Height="30"
                        HorizontalAlignment="Left"
                        FontSize="17"
                        PreviewKeyDown="LName_KeyDown" />
                </StackPanel>
                <StackPanel
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal">
                    <Label
                        Grid.Row="2"
                        Grid.Column="0"
                        Width="120"
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource NumberLB}"
                        FontSize="15" />
                    <TextBox
                        Name="Phone"
                        Grid.ColumnSpan="2"
                        Width="300"
                        Height="30"
                        HorizontalAlignment="Left"
                        FontSize="17"
                        PreviewKeyDown="Phone_KeyDown"
                        PreviewTextInput="Phone_PreviewTextInput" />
                </StackPanel>
                <StackPanel
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal">
                    <Label
                        Width="120"
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource CCPLB}"
                        FontSize="15" />
                    <TextBox
                        Name="CCP"
                        Grid.ColumnSpan="2"
                        Width="300"
                        Height="30"
                        HorizontalAlignment="Left"
                        FontSize="15"
                        PreviewKeyDown="CCP_KeyDown" />
                </StackPanel>
                <StackPanel
                    Grid.Row="4"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal">
                    <Label
                        Grid.Row="2"
                        Grid.Column="0"
                        Width="120"
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource AdressLB}"
                        FontSize="15" />
                    <TextBox
                        Name="Adress"
                        Grid.ColumnSpan="2"
                        Width="300"
                        Height="30"
                        HorizontalAlignment="Left"
                        FontSize="15"
                        PreviewKeyDown="Adress_KeyDown" />
                </StackPanel>
                <StackPanel
                    Grid.Row="5"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal">
                    <Label
                        Grid.Row="2"
                        Grid.Column="0"
                        Width="120"
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource EmailLB}"
                        FontSize="15" />
                    <TextBox
                        Name="Email"
                        Grid.ColumnSpan="2"
                        Width="300"
                        Height="30"
                        HorizontalAlignment="Left"
                        FontSize="15"
                        PreviewKeyDown="Email_PreviewKeyDown" />
                </StackPanel>

                <StackPanel
                    Grid.Row="6"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal">
                    <Label
                        Grid.Row="2"
                        Grid.Column="0"
                        Width="120"
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource NoteLB}"
                        FontSize="15" />
                    <TextBox
                        Name="Note"
                        Grid.ColumnSpan="2"
                        Width="300"
                        Height="30"
                        HorizontalAlignment="Left"
                        FontSize="17"
                        PreviewKeyDown="Note_KeyDown" />
                </StackPanel>

                <StackPanel
                    Grid.Row="7"
                    Grid.Column="0"
                    Grid.ColumnSpan="4"
                    Orientation="Horizontal">
                    <Label
                        Width="120"
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource GenderLB}"
                        FontSize="15" />
                    <ComboBox
                        Name="Gender"
                        Grid.Row="6"
                        Grid.Column="0"
                        Width="90"
                        Height="30"
                        HorizontalAlignment="Center"
                        FontSize="15">
                        <ComboBoxItem Content="{DynamicResource Male}" />
                        <ComboBoxItem Content="{DynamicResource Female}" />
                    </ComboBox>
                    <Label
                        Width="85"
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource BirthDateLB}"
                        FontSize="15" />
                    <DatePicker
                        Name="Date"
                        Width="125"
                        Height="30"
                        VerticalAlignment="Center"
                        FontSize="15" />

                </StackPanel>
                <Border
                    Grid.Row="1"
                    Grid.RowSpan="3"
                    Grid.Column="3"
                    Width="120"
                    Height="120"
                    VerticalAlignment="Bottom"
                    BorderBrush="Black"
                    BorderThickness="2">
                    <Image
                        Name="TPicture"
                        Grid.Row="0"
                        Width="120"
                        Height="120"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Stretch="UniformToFill" />
                </Border>
                <StackPanel
                    Grid.Row="4"
                    Grid.Column="3"
                    Grid.ColumnSpan="2"
                    Width="120"
                    Height="30"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Width="30"
                        Margin="5,0,10,0"
                        Background="Transparent"
                        Click="Button_Click_2">
                        <StackPanel>
                            <Image HorizontalAlignment="Center" Source="/Images/Scan.png" />
                        </StackPanel>
                    </Button>
                    <Button
                        Width="30"
                        Margin="0,0,10,0"
                        Background="Transparent"
                        Click="Button_Click_3">
                        <StackPanel>
                            <Image HorizontalAlignment="Center" Source="/Images/Crop.png" />
                        </StackPanel>
                    </Button>
                    <Button
                        Width="30"
                        Background="Transparent"
                        Click="Button_Click_4">
                        <StackPanel>
                            <Image HorizontalAlignment="Center" Source="/Images/Folder.png" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <Button
                    Grid.Row="11"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Width="100"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="Button_Click"
                    Content="{DynamicResource Cancel}" />
                <Button
                    Grid.Row="11"
                    Grid.Column="2"
                    Grid.ColumnSpan="2"
                    Width="100"
                    Height="25"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="SubmitT"
                    Content="{DynamicResource Insert}" />

            </Grid>
        </TabItem>
        <TabItem Name="FreeTime">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Images/Time.png" />
                    <Label Content="{DynamicResource FreeTime}" FontSize="12" />
                </StackPanel>
            </TabItem.Header>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="10*" />
                </Grid.RowDefinitions>
                <StackPanel
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="4"
                    Orientation="Horizontal">
                    <Label
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource Day}"
                        FontSize="15" />
                    <ComboBox
                        Name="Day"
                        Width="100"
                        Height="25"
                        FontSize="15">
                        <ComboBoxItem Content="{DynamicResource Sunday}" />
                        <ComboBoxItem Content="{DynamicResource Monday}" />
                        <ComboBoxItem Content="{DynamicResource Tuesday}" />
                        <ComboBoxItem Content="{DynamicResource Wednesday}" />
                        <ComboBoxItem Content="{DynamicResource Thursday}" />
                        <ComboBoxItem Content="{DynamicResource Friday}" />
                        <ComboBoxItem Content="{DynamicResource Saturday}" />
                    </ComboBox>
                    <Label
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource FromLB}"
                        FontSize="15" />
                    <ComboBox
                        Name="HFrom"
                        Width="50"
                        Height="25"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="15"
                        IsEditable="False"
                        IsReadOnly="True"
                        IsTextSearchEnabled="True">
                        <ComboBoxItem Content="08" />
                        <ComboBoxItem Content="09" />
                        <ComboBoxItem Content="10" />
                        <ComboBoxItem Content="11" />
                        <ComboBoxItem Content="12" />
                        <ComboBoxItem Content="13" />
                        <ComboBoxItem Content="14" />
                        <ComboBoxItem Content="15" />
                        <ComboBoxItem Content="16" />
                        <ComboBoxItem Content="17" />
                        <ComboBoxItem Content="18" />
                        <ComboBoxItem Content="19" />
                        <ComboBoxItem Content="20" />
                        <ComboBoxItem Content="21" />
                        <ComboBoxItem Content="22" />
                        <ComboBoxItem Content="23" />
                    </ComboBox>
                    <Label
                        VerticalContentAlignment="Center"
                        Content=" : "
                        FontSize="15" />
                    <ComboBox
                        Name="MFrom"
                        Width="50"
                        Height="25"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="15"
                        IsEditable="False"
                        IsReadOnly="True"
                        IsTextSearchEnabled="True">
                        <ComboBoxItem Content="00" />
                        <ComboBoxItem Content="15" />
                        <ComboBoxItem Content="30" />
                        <ComboBoxItem Content="45" />
                    </ComboBox>
                    <Label
                        VerticalContentAlignment="Center"
                        Content="{DynamicResource ToLB}"
                        FontSize="15" />
                    <ComboBox
                        Name="HTo"
                        Width="50"
                        Height="25"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="15"
                        IsReadOnly="True"
                        IsTextSearchEnabled="True">
                        <ComboBoxItem Content="08" />
                        <ComboBoxItem Content="09" />
                        <ComboBoxItem Content="10" />
                        <ComboBoxItem Content="11" />
                        <ComboBoxItem Content="12" />
                        <ComboBoxItem Content="13" />
                        <ComboBoxItem Content="14" />
                        <ComboBoxItem Content="15" />
                        <ComboBoxItem Content="16" />
                        <ComboBoxItem Content="17" />
                        <ComboBoxItem Content="18" />
                        <ComboBoxItem Content="19" />
                        <ComboBoxItem Content="20" />
                        <ComboBoxItem Content="21" />
                        <ComboBoxItem Content="22" />
                        <ComboBoxItem Content="23" />
                    </ComboBox>
                    <Label
                        VerticalContentAlignment="Center"
                        Content=" : "
                        FontSize="20" />
                    <ComboBox
                        Name="MTo"
                        Width="50"
                        Height="25"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="15"
                        IsReadOnly="True"
                        IsTextSearchEnabled="True">
                        <ComboBoxItem Content="00" />
                        <ComboBoxItem Content="15" />
                        <ComboBoxItem Content="30" />
                        <ComboBoxItem Content="45" />
                        <ComboBoxItem Content="55" />
                    </ComboBox>
                    <Button
                        Width="50"
                        Height="25"
                        Click="Button_Click_1"
                        Content="+" />

                </StackPanel>

                <DataGrid
                    Name="DGFreeTime"
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    ItemsSource="{Binding}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="120" Binding="{Binding Day}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Day}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Width="120" Binding="{Binding TimeStart}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource TimeStart}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Width="120" Binding="{Binding TimeEnd}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Time End}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Width="50" Header="">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Name="BtnDelete" Click="BtnDeleteFree_Click">
                                        <Image
                                            Width="80"
                                            Height="20"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Source="/Images/DeleteIconsmall.png" />

                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>
        <TabItem Name="Payment">
            <TabItem.Header>
                <StackPanel Orientation="Horizontal">
                    <Image
                        Width="25"
                        Height="25"
                        Source="/Images/Payment.png" />
                    <Label Content="{DynamicResource Payment}" FontSize="12" />
                </StackPanel>
            </TabItem.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="55" />

                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Row="0"
                    Grid.ColumnSpan="1"
                    Width="100"
                    Height="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="Button_Click_Add">
                    <StackPanel Orientation="Horizontal">
                        <Image
                            Margin="0,7,0,0"
                            VerticalAlignment="Center"
                            Source="/Images/Payment.png" />
                        <Label
                            VerticalAlignment="Center"
                            Content="{DynamicResource Add}"
                            FontSize="15" />
                    </StackPanel>
                </Button>

                <Button
                    Grid.Row="0"
                    Grid.Column="1"
                    Width="100"
                    Height="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="Button_Click_Delete">
                    <StackPanel Orientation="Horizontal">
                        <Image Margin="0,0,0,0" Source="/Images/Deleteiconsmall.png" />
                        <Label
                            VerticalAlignment="Center"
                            Content="{DynamicResource Delete}"
                            FontSize="15" />
                    </StackPanel>
                </Button>

                <Button
                    Grid.Row="0"
                    Grid.Column="2"
                    Width="100"
                    Height="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="Button_Click_Print">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Images/Print.png" />
                        <Label
                            VerticalAlignment="Center"
                            Content="{DynamicResource Print}"
                            FontSize="15" />
                    </StackPanel>
                </Button>

                <DataGrid
                    Name="DGPay"
                    Grid.Row="2"
                    Grid.ColumnSpan="3"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    AutoGenerateColumns="False"
                    FontSize="13"
                    IsReadOnly="True"
                    ItemsSource="{Binding}"
                    MouseDoubleClick="DGPay_MouseDoubleClick"
                    SelectionMode="Single"
                    SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="110"
                            Binding="{Binding Name}"
                            Header="Teacher Name"
                            Visibility="Collapsed" />
                        <DataGridTextColumn Binding="{Binding GroupName}" FontSize="10">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource GroupName}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding Date}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Date}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding FromSesDate}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource StartDatePay}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding ToSesDate}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource EndDatePay}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding TotalSesTeacher}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource SumSesTeacher}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding TotalP}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource TotalP}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                        <DataGridTextColumn Binding="{Binding Note}">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{DynamicResource Note}" />
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>
    </TabControl>





</Window>
