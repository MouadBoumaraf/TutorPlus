<Window
    x:Class="Gestion_De_Cours.Panels.DataGridWithSearch"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Gestion_De_Cours.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DataGridWithSearch"
    Width="300"
    Height="450"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
            <Label
                Margin="10"
                VerticalAlignment="Center"
                Content="{DynamicResource SearchLB}"
                FontSize="15" />
            <TextBox
                Name="TBSearch"
                Width="200"
                Height="35"
                TextChanged="TextBox_TextChanged" />
        </StackPanel>
        <DataGrid
            Name="DG"
            Grid.Row="1"
            Margin="10"
            AutoGenerateColumns="False"
            FontSize="15"
            IsReadOnly="True"
            ItemsSource="{Binding}"
            MouseDoubleClick="DG_MouseDoubleClick">
            <DataGrid.Columns>

                <DataGridTextColumn
                    x:Name="date"
                    Width="100"
                    Binding="{Binding Date}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource Date}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn
                    x:Name="Status"
                    Width="100"
                    Binding="{Binding StatusText}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource Presense}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn
                    x:Name="Session"
                    Width="100"
                    Binding="{Binding Ses}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource Session}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn
                    x:Name="group"
                    Width="100"
                    Binding="{Binding GroupName}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource Group}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
