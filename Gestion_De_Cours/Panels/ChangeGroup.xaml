<Window
    x:Class="Gestion_De_Cours.Panels.ChangeGroup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
    xmlns:local="clr-namespace:Gestion_De_Cours.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Change Group"
    Width="1150"
    Height="100"
    dx:ThemeManager.ThemeName="None"
    Closed="Window_Closed"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <StackPanel
            Name="SPMoveS"
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Label
                Name="LBAttendance"
                VerticalAlignment="Center"
                VerticalContentAlignment="Top"
                Content="{DynamicResource Attendancelb}"
                FontSize="20" />
            <dxe:ComboBoxEdit
                Name="CBAttendance"
                Width="130"
                Height="40"
                VerticalAlignment="Center"
                dx:ThemeManager.ThemeName="Office2019Colorful"
                DisplayMember="Text"
                EditValueChanged="CBAttendance_EditValueChanged"
                FontSize="15"
                ItemsSource="{Binding}"
                Visibility="Visible" />
            <Label
                VerticalAlignment="Center"
                VerticalContentAlignment="Top"
                Content="{DynamicResource GroupLB}"
                FontSize="20" />
            <dxe:ComboBoxEdit
                Name="CBGroup"
                Width="130"
                Height="40"
                VerticalAlignment="Center"
                dx:ThemeManager.ThemeName="Office2019Colorful"
                DisplayMember="GroupName"
                EditValueChanged="CBGroup_EditValueChanged"
                FontSize="15"
                ItemsSource="{Binding}"
                Visibility="Visible" />
            <Label
                Name="LBStudent"
                VerticalAlignment="Center"
                Content="{DynamicResource StudentLB}"
                FontSize="20" />
            <dxe:ComboBoxEdit
                xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                Name="CBStudent"
                Width="200"
                Height="50"
                Margin="5"
                dx:ThemeManager.ThemeName="Office2019Colorful"
                AllowCollectionView="False"
                AutoComplete="True"
                DisplayMember="Name"
                FilterCondition="Contains"
                FontSize="20"
                ImmediatePopup="True"
                IncrementalFiltering="True"
                IsTextEditable="True"
                ItemsSource="{Binding}"
                Visibility="Visible">
                <dxe:ComboBoxEdit.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Image
                                Width="50"
                                Height="45"
                                Source="{Binding Picture}" />
                            <Label VerticalAlignment="Center" Content="{Binding Name}">
                                <Label.Resources>
                                    <Style TargetType="{x:Type Label}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Gender}" Value="0">
                                                <Setter Property="Foreground" Value="Blue" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Gender}" Value="1">
                                                <Setter Property="Foreground" Value="Pink" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Label.Resources>
                            </Label>
                        </StackPanel>
                    </DataTemplate>
                </dxe:ComboBoxEdit.ItemTemplate>
            </dxe:ComboBoxEdit>

            <StackPanel
                Name="SPTypeChange"
                VerticalAlignment="Center"
                Orientation="Vertical"
                Visibility="Visible">

                <RadioButton
                    Name="OneTime"
                    Margin="5"
                    Checked="OneTime_Checked"
                    Content="{DynamicResource OneTimeSes}"
                    Unchecked="OneTime_Unchecked" />
                <RadioButton
                    Name="ClassJoin"
                    Margin="5"
                    Content="{DynamicResource ChangeGroup}"
                    RenderTransformOrigin="0.5,0.5" />
            </StackPanel>
            <Label
                Name="FromLB"
                VerticalAlignment="Center"
                Content="{DynamicResource FromLB}"
                FontSize="15" />
            <DatePicker
                Name="DateGroupChange"
                Width="150"
                Height="30"
                VerticalAlignment="Center"
                FontSize="15"
                Language="fr-FR" />
            <Button
                Width="45"
                Height="45"
                Margin="10,0,0,0"
                Background="Transparent"
                BorderBrush="Transparent"
                Click="btn_InsertGroupChange"
                FontSize="15">
                <StackPanel>
                    <Image
                        Width="40"
                        Height="40"
                        Source="/Images/addsign.png" />
                </StackPanel>
            </Button>
        </StackPanel>

    </Grid>
</Window>
