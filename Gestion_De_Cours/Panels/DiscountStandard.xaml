<Window
    x:Class="Gestion_De_Cours.Panels.DiscountStandard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:local="clr-namespace:Gestion_De_Cours.Panels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DiscountStandard"
    Width="1050"
    Height="450"
    dx:ThemeManager.ThemeName="None"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <FontFamily x:Key="FontLabel">pack://application:,,,/Fonts/#Droid Arabic Kufi</FontFamily>
                </ResourceDictionary>
                <ResourceDictionary Source="../Dictionary\EN.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Name="Row1" Height="60" />
            <RowDefinition Name="Row2" />
        </Grid.RowDefinitions>

        <!--  ComboBox to select type 1 or type 2  -->
        <StackPanel
            Grid.Row="0"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <Label VerticalAlignment="Center" Content="Type : " />
            <ComboBox
                Name="typeComboBox"
                Width="60"
                Height="20"
                Margin="0,0,0,0"
                VerticalAlignment="Center"
                SelectionChanged="typeComboBox_SelectionChanged">
                <ComboBoxItem VerticalAlignment="Top" Content="Type 1" />
                <ComboBoxItem VerticalAlignment="Top" Content="Type 2" />
            </ComboBox>
            <Label VerticalAlignment="Center" Content="Level :" />
            <ComboBox
                Name="CLevel"
                Width="80"
                Height="20"
                DisplayMemberPath="Level"
                ItemsSource="{Binding}"
                SelectedValuePath="ID"
                SelectionChanged="CLevel_SelectionChanged" />
            <Label
                VerticalAlignment="Center"
                VerticalContentAlignment="Center"
                Content="Year :" />
            <ComboBox
                Name="CYear"
                Width="80"
                Height="20"
                DisplayMemberPath="Year"
                ItemsSource="{Binding}"
                SelectedValuePath="ID"
                SelectionChanged="CYear_SelectionChanged" />
            <ComboBox
                Name="CBYear"
                Width="120"
                Height="30"
                Visibility="Collapsed">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Name="ItemTextBlockYear"
                                Margin="0,0,5,0"
                                Text="{Binding Year}" />
                            <CheckBox
                                Name="checkBoxYear"
                                Checked="checkBoxYear_Checked"
                                IsChecked="{Binding IsChecked}"
                                Unchecked="checkBoxYear_Unchecked" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <!--
            <Label VerticalAlignment="Center" Name="SpecLB" Content="Speciality :" VerticalContentAlignment="Center"> </Label>
            <ComboBox Name="CSpeciality"   SelectedValuePath="ID"  DisplayMemberPath="Speciality"  ItemsSource="{Binding }"  Height="20" Width="80"   >
            </ComboBox>-->
            <StackPanel
                Name="SPType1"
                Grid.Row="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Visibility="Collapsed">
                <!--  Comboboxes for type 1  -->
                <Label VerticalAlignment="Center" Content="Subjects : " />
                <StackPanel
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
                    <StackPanel Height="30">
                        <ComboBox
                            Name="subjectComboBox1"
                            Width="100"
                            Height="20"
                            Margin="0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectComboBox1_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Height="30">
                        <ComboBox
                            Name="subjectComboBox2"
                            Width="100"
                            Height="20"
                            Margin="0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectComboBox2_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Height="30">
                        <ComboBox
                            Name="subjectComboBox3"
                            Width="100"
                            Height="20"
                            Margin="0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectComboBox3_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Height="30">
                        <ComboBox
                            Name="subjectComboBox4"
                            Width="100"
                            Height="20"
                            Margin="0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectComboBox4_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Height="30">
                        <ComboBox
                            Name="subjectComboBox5"
                            Width="100"
                            Height="20"
                            Margin="0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectComboBox5_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Height="30">
                        <ComboBox
                            Name="subjectComboBox6"
                            Width="100"
                            Height="20"
                            Margin="0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectComboBox6_SelectionChanged" />
                    </StackPanel>
                </StackPanel>

                <Label
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Content="Discounts in:" />
                <!--  Five rows with price and teacher price TextBoxes  -->
                <StackPanel
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Visibility="Visible">
                    <StackPanel Height="30" Orientation="Horizontal">
                        <ComboBox
                            Name="subjectDiscComboBox1"
                            Width="100"
                            Height="20"
                            Margin="0,5,0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectDiscComboBox1_SelectionChanged" />
                        <Label VerticalAlignment="Center" Content="Price :" />
                        <TextBox
                            Name="TBPrice1"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                        <Label Content="Teacher Price :" />
                        <TextBox
                            Name="TBTPrice1"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Height="30" Orientation="Horizontal">
                        <ComboBox
                            Name="subjectDiscComboBox2"
                            Width="100"
                            Height="20"
                            Margin="0,5,0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectDiscComboBox2_SelectionChanged" />
                        <Label VerticalAlignment="Center" Content="Price :" />
                        <TextBox
                            Name="TBPrice2"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                        <Label Content="Teacher Price :" />
                        <TextBox
                            Name="TBTPrice2"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Height="30" Orientation="Horizontal">
                        <ComboBox
                            Name="subjectDiscComboBox3"
                            Width="100"
                            Height="20"
                            Margin="0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectDiscComboBox3_SelectionChanged" />
                        <Label VerticalAlignment="Center" Content="Price :" />
                        <TextBox
                            Name="TBPrice3"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                        <Label Content="Teacher Price :" />
                        <TextBox
                            Name="TBTPrice3"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Height="30" Orientation="Horizontal">
                        <ComboBox
                            Name="subjectDiscComboBox4"
                            Width="100"
                            Height="20"
                            Margin="0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectDiscComboBox4_SelectionChanged" />
                        <Label Content="Price :" />
                        <TextBox
                            Name="TBPrice4"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                        <Label VerticalAlignment="Center" Content="Teacher Price :" />
                        <TextBox
                            Name="TBTPrice4"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Height="30" Orientation="Horizontal">
                        <ComboBox
                            Name="subjectDiscComboBox5"
                            Width="100"
                            Height="20"
                            Margin="0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectDiscComboBox5_SelectionChanged" />
                        <Label Content="Price :" />
                        <TextBox
                            Name="TBPrice5"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                        <Label Content="Teacher Price :" />
                        <TextBox
                            Name="TBTPrice5"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Height="30" Orientation="Horizontal">
                        <ComboBox
                            Name="subjectDiscComboBox6"
                            Width="100"
                            Height="20"
                            Margin="0,5,0,5"
                            DisplayMemberPath="Subject"
                            ItemsSource="{Binding}"
                            SelectedValuePath="ID"
                            SelectionChanged="subjectDiscComboBox6_SelectionChanged" />
                        <Label Content="Price :" />
                        <TextBox
                            Name="TBPrice6"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                        <Label Content="Teacher Price :" />
                        <TextBox
                            Name="TBTPrice6"
                            Width="50"
                            Height="20"
                            VerticalAlignment="Center" />
                    </StackPanel>

                </StackPanel>
            </StackPanel>
            <!--  ComboBox and TextBox for type 2  -->
            <StackPanel
                Name="SPType2"
                Height="50"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Orientation="Horizontal"
                Visibility="Visible">
                <Label
                    Margin="0,5"
                    VerticalAlignment="Center"
                    Content="Amount of Subjects :" />
                <ComboBox
                    Name="CBAmmountOFSubjects"
                    Width="50"
                    Height="20"
                    Margin="0,5"
                    SelectionChanged="CBAmmountOFSubjects_SelectionChanged">
                    <ComboBoxItem VerticalAlignment="Top" Content="6" />
                    <ComboBoxItem VerticalAlignment="Top" Content="5" />
                    <ComboBoxItem VerticalAlignment="Top" Content="4" />
                    <ComboBoxItem VerticalAlignment="Top" Content="3" />
                    <ComboBoxItem VerticalAlignment="Top" Content="2" />
                    <ComboBoxItem VerticalAlignment="Top" Content="1" />
                </ComboBox>
                <Label VerticalAlignment="Center" Content="Minus Price :" />
                <TextBox
                    Name="TBMinusPrice"
                    Width="60"
                    Height="20" />
                <Label VerticalAlignment="Center" Content="Minus Teacher Price :" />
                <TextBox
                    Name="TBMinusTPrice"
                    Width="60"
                    Height="20" />
            </StackPanel>
            <Button
                Width="60"
                Height="20"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Click="Button_Click"
                Content="+" />
        </StackPanel>
        <!--  DataGrid to show discounts  -->
        <DataGrid
            Name="DGDiscounts"
            Grid.Row="3"
            Grid.RowSpan="1"
            Grid.Column="0"
            Margin="5"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            ItemsSource="{Binding}"
            SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Width="auto" Binding="{Binding Type}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource Type}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>


                <DataGridTextColumn Width="auto" Binding="{Binding Level}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource Level}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn Width="auto" Binding="{Binding Year}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource Year}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn
                    x:Name="Type1Subject"
                    Width="auto"
                    Binding="{Binding Subjects}"
                    Visibility="Collapsed">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource Subject}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>


                <DataGridTextColumn
                    x:Name="Type1SubjectDiscount"
                    Width="auto"
                    Binding="{Binding SubjectDiscount}"
                    Visibility="Collapsed">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource SubjectDiscount}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn
                    x:Name="Type2AmmountSubjects"
                    Width="auto"
                    Binding="{Binding AmmountSubjects}"
                    Visibility="Collapsed">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource AmmountOFSubjects}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn
                    x:Name="Type2MinusPrice"
                    Width="auto"
                    Binding="{Binding MPrice}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource DiscountInSPrice}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>

                <DataGridTextColumn
                    x:Name="Type2MinusTPrice"
                    Width="auto"
                    Binding="{Binding MTPrice}">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{DynamicResource DiscountInSTPrice}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</Window>
